    },
    {
      "start": 98.76,
      "end": 99.96000000000001,
      "text": "它是一个非常短暂的时间"
    },
    {
      "start": 99.96000000000001,
      "end": 101.92,
      "text": "人在一刹那之间有3000导司"
    },
    {
      "start": 101.92,
      "end": 103.24000000000001,
