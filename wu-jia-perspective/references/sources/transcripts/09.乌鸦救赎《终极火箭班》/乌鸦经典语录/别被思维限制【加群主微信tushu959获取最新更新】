    },
    {
      "start": 92.08,
      "end": 94.0,
      "text": "人的可能性在一刹那之间"
    },
    {
      "start": 94.0,
      "end": 95.36,
      "text": "就是说佛教说的一刹那"
    },
    {
      "start": 95.36,
      "end": 97.08,
