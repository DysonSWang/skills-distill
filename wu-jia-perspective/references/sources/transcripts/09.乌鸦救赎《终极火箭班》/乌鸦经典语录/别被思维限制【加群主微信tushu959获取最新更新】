    },
    {
      "start": 118.80000000000001,
      "end": 119.60000000000001,
      "text": "但是你却想了"
    },
    {
      "start": 119.60000000000001,
      "end": 121.2,
      "text": "我万一留不住他呢"
    },
    {
      "start": 121.2,
      "end": 122.48,
      "text": "ok 那么那个可能性"
    },
    {
      "start": 122.48,
      "end": 123.52000000000001,
