  "segments": [
    {
      "start": 0.0,
      "end": 3.2800000000000002,
      "text": "獨立生存之四個字很重要的"
    },
    {
      "start": 3.2800000000000002,
      "end": 5.28,
      "text": "自己做一個60平米或者50平米"
    },
    {
      "start": 5.28,
      "end": 6.92,
      "text": "哪怕40平米的一個小房子"
    },
    {
      "start": 6.92,
      "end": 7.76,
      "text": "一時一廳"
    },
    {
      "start": 7.76,
      "end": 8.96,
      "text": "有空調有電視"
    },
    {
      "start": 8.96,
      "end": 9.84,
      "text": "挺舒服的"
    },
    {
      "start": 9.84,
      "end": 11.16,
      "text": "雖然說裝修破一點"
    },
    {
      "start": 11.16,
      "end": 12.0,
      "text": "還好啦"
    },
    {
      "start": 12.0,
      "end": 12.56,
      "text": "好吧"
    },
    {
      "start": 12.56,
      "end": 14.8,
      "text": "你會發現這樣的男人就更有心理的"
    },
    {
      "start": 14.8,
      "end": 15.88,
      "text": "因為你知道嗎"
    },
    {
      "start": 15.88,
      "end": 17.32,
      "text": "我到了深圳之後"
    },
    {
      "start": 17.32,
      "end": 19.32,
      "text": "據我的了解"
    },
    {
      "start": 19.32,
      "end": 20.48,
      "text": "據我的了解"
    },
    {
      "start": 20.48,
      "end": 22.48,
      "text": "據我的觀察"
    },
    {
      "start": 22.48,
      "end": 23.8,
      "text": "一個女孩"
    },
    {
      "start": 23.8,
      "end": 25.04,
      "text": "尤其是"
    },
    {
      "start": 25.04,
      "end": 27.240000000000002,
      "text": "你讓我這種人已經算是什麼了"
    },
    {
      "start": 27.240000000000002,
      "end": 27.68,
      "text": "對吧"
    },
    {
      "start": 27.68,
      "end": 29.12,
      "text": "你們說我是人精"
    },
    {
      "start": 29.12,
      "end": 30.12,
      "text": "老師我老油條"
    },
    {
      "start": 30.12,
      "end": 30.92,
      "text": "我都認可了"
    },
    {
      "start": 30.92,
      "end": 31.8,
      "text": "我也不想去解釋"
    },
    {
      "start": 31.8,
      "end": 34.8,
      "text": "因為確實展現出很多這種東西"
    },
    {
      "start": 34.8,
      "end": 37.32,
      "text": "我這樣的人就不說啥了"
    },
    {
      "start": 37.32,
      "end": 38.68,
      "text": "一個男孩"
    },
    {
      "start": 38.68,
      "end": 39.24,
      "text": "哥"
    },
    {
      "start": 39.24,
      "end": 42.08,
      "text": "又大把想不通事情的"
    },
    {
      "start": 42.08,
      "end": 44.160000000000004,
      "text": "一個男孩又大把想不通事情"
    },
    {
      "start": 44.160000000000004,
      "end": 45.84,
      "text": "一個20多次的女孩"
    },
    {
      "start": 45.84,
      "end": 47.760000000000005,
      "text": "21、23、24歲"
    },
    {
      "start": 47.760000000000005,
      "end": 49.760000000000005,
      "text": "你跟他聊天"
    },
    {
      "start": 49.760000000000005,
      "end": 50.52,
      "text": "啊"
    },
    {
      "start": 50.52,
      "end": 52.36,
      "text": "你跟他聊天"
    },
    {
      "start": 52.36,
      "end": 54.120000000000005,
      "text": "真的我說他傻白天是客氣的"
    },
    {
      "start": 54.120000000000005,
      "end": 54.760000000000005,
      "text": "明白嗎"
    },
    {
      "start": 54.760000000000005,
      "end": 56.480000000000004,
      "text": "是說好聽的"
    },
    {
      "start": 56.480000000000004,
      "end": 57.2,
      "text": "說到男人聽點"
    },
    {
      "start": 57.2,
      "end": 58.44,
      "text": "就跟他那邊傻逼一樣"
    },
    {
      "start": 58.44,
      "end": 60.64,
      "text": "什麼都不知道"
    },
    {
      "start": 60.64,
      "end": 62.68,
      "text": "他的大腦對於未來的理解"
    },
    {
      "start": 62.68,
      "end": 64.08,
      "text": "或者對於現實世界的理解"
    },
    {
      "start": 64.08,
      "end": 66.64,
      "text": "完全是按照電視劇的方式來構造"
    },
    {
      "start": 66.64,
      "end": 68.6,
      "text": "他等待有一天有一個白馬王子"
    },
    {
      "start": 68.6,
      "end": 70.28,
      "text": "騎著這個白馬來接他"
    },
    {
      "start": 70.28,
      "end": 72.2,
      "text": "不會有那一天的"
    },
    {
      "start": 72.2,
      "end": 77.24,
      "text": "然後你會發現90%以上的女孩"
    },
    {
      "start": 77.24,
      "end": 80.2,
      "text": "生活及其就過"
    },
    {
      "start": 80.2,
      "end": 81.52,
      "text": "明白嗎"
    },
    {
      "start": 81.52,
      "end": 83.2,
      "text": "不要被朋友圈所迷惑"
    },
    {
      "start": 83.2,
      "end": 85.47999999999999,
      "text": "你把女孩的朋友圈看起來很矯"
    },
    {
      "start": 85.47999999999999,
      "end": 88.16,
      "text": "其實就是我說的那種包裝出來的"
    },
    {
      "start": 88.16,
      "end": 89.6,
      "text": "他其實每天也是"
    },
    {
      "start": 89.6,
      "end": 91.32,
      "text": "把自己打包的像個仙女一樣"
    },
    {
      "start": 91.32,
      "end": 94.96,
      "text": "然後逼著頭出了同一個10米米的房間出來"
    },
    {
      "start": 94.96,
      "end": 95.96,
      "text": "然後踏踏關上門"
    },
    {
      "start": 95.96,
      "end": 96.75999999999999,
      "text": "坐上車"
    },
    {
      "start": 96.75999999999999,
      "end": 98.36,
      "text": "然後背著自己的LV"
    },
    {
      "start": 98.36,
      "end": 100.96,
      "text": "然後趕工交"
    },
    {
      "start": 100.96,
      "end": 101.8,
      "text": "背著自己的LV"
    },
    {
      "start": 101.8,
      "end": 104.52,
      "text": "然後去趕工交"
    },
    {
      "start": 104.52,
      "end": 104.84,
      "text": "可以了"
    },
    {
      "start": 104.84,
      "end": 108.28,
      "text": "所以說90%的女孩是及其就過的"
    }
  ]
