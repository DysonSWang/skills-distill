      "start": 3794.2000000000003,
      "end": 3795.0800000000004,
      "text": "没问题的"
    },
    {
      "start": 3795.0800000000004,
      "end": 3796.32,
      "text": "她只是一个称呼语"
    },
    {
      "start": 3800.2000000000003,
      "end": 3801.1200000000003,
      "text": "OK"
    },
    {
      "start": 3801.1200000000003,
      "end": 3803.0400000000004,
      "text": "我看大家也都没什么问题"
    },
    {
      "start": 3806.6800000000003,
      "end": 3807.48,
      "text": "嗯"
    },
    {
      "start": 3811.48,
      "end": 3812.44,
      "text": "这边上上上所了"
    },
    {
      "start": 3812.44,
      "end": 3814.0800000000004,
      "text": "要上厕所扣1啊"
    },
    {
      "start": 3814.0800000000004,
      "end": 3815.6800000000003,
      "text": "我们试试两分钟"
    },
    {
      "start": 3815.6800000000003,
      "end": 3817.5200000000004,
      "text": "我先把这个录音先填一下"
    },
    {
      "start": 3817.5200000000004,
      "end": 3818.5200000000004,
      "text": "这是第一节课了"
    },
    {
      "start": 3834.5200000000004,
      "end": 3835.5200000000004,
      "text": "我扭一下"
    },
    {
      "start": 3835.52,
      "end": 3836.72,
      "text": "你们先上厕所啊"
    },
    {
      "start": 3836.72,
      "end": 3838.96,
      "text": "我直接把这个录音就给到客服那边"
    },
    {
      "start": 3838.96,
      "end": 3840.48,
      "text": "让他们去到时候去上船"
    },
    {
      "start": 3844.32,
      "end": 3844.6,
      "text": "哎"
    },
    {
      "start": 3844.6,
      "end": 3846.24,
      "text": "其实兄弟们你知道吗"
    },
    {
      "start": 3846.24,
      "end": 3848.0,
      "text": "我我所讲的就是核心"
    },
    {
      "start": 3848.0,
      "end": 3850.64,
      "text": "你就照着我这个干就可以了"
    },
    {
      "start": 3850.64,
      "end": 3851.28,
      "text": "因为啥呢"
    },
    {
      "start": 3851.28,
      "end": 3852.92,
      "text": "很多时候就像当年"
    },
    {
      "start": 3852.92,
      "end": 3854.0,
      "text": "其实没那么多事"
    },
    {
      "start": 3854.0,
      "end": 3855.04,
      "text": "就他妈被你们问的"
    },
    {
      "start": 3855.04,
      "end": 3855.72,
      "text": "问问问"
    },
    {
      "start": 3855.72,
      "end": 3856.6,
      "text": "把事儿给我问出来"
    },
    {
      "start": 3856.6,
      "end": 3857.68,
      "text": "其实没有"
    },
    {
      "start": 3857.68,
      "end": 3859.2,
      "text": "但是为了回答你这个问题"
    },
    {
      "start": 3859.2,
      "end": 3860.48,
      "text": "搞出来的概念"
    },
    {
      "start": 3860.48,
      "end": 3861.16,
      "text": "其实没有"
    },
    {
      "start": 3861.16,
      "end": 3863.72,
      "text": "你在实际操作时候根本就遇不到那些事情"
    },
    {
      "start": 3865.96,
      "end": 3867.4,
      "text": "前两个话题怎么连接"
    },
    {
      "start": 3867.4,
      "end": 3868.36,
      "text": "没两个话题啊"
    },
    {
      "start": 3869.6,
      "end": 3872.2,
      "text": "录音我们会放到小的通上面去啊"
    },
    {
      "start": 3872.2,
      "end": 3873.16,
      "text": "没有结束啊"
    },
    {
      "start": 3873.16,
      "end": 3875.44,
      "text": "马上我们就要开始第二节课了"
    },
    {
      "start": 3875.44,
      "end": 3876.32,
      "text": "马上我们"
    }
  ]
}