    {
      "start": 821.9,
      "end": 822.9,
      "text": "概念一说里讲"
    },
    {
      "start": 822.9,
      "end": 823.9,
      "text": "就完事了"
    },
    {
      "start": 823.9,
      "end": 824.9,
      "text": "有多难"
    },
    {
      "start": 827.9,
      "end": 828.9,
      "text": "装久了"
    },
    {
      "start": 828.9,
      "end": 829.9,
      "text": "真的是这样的事"
    },
    {
      "start": 829.9,
      "end": 830.9,
      "text": "装久了真的就会变成13"
    },
    {
      "start": 830.9,
      "end": 831.9,
      "text": "装不必装久了"
    },
    {
      "start": 831.9,
      "end": 833.9,
      "text": "真的会变成个B"
