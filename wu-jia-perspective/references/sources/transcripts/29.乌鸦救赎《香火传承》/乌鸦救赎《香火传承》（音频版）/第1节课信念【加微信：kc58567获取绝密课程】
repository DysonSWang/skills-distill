    {
      "start": 4136.719999999999,
      "end": 4137.2,
      "text": "对吧"
    },
    {
      "start": 4137.2,
      "end": 4137.5199999999995,
      "text": "然后"
    },
    {
      "start": 4142.639999999999,
      "end": 4144.96,
      "text": "你看没见过保姆的界限"
