    {
      "start": 4116.8,
      "end": 4118.96,
      "text": "必须身边有点这种知心知家"
    },
    {
      "start": 4118.96,
      "end": 4120.64,
      "text": "永远为他捍卫利益的人"
    },
    {
      "start": 4120.64,
      "end": 4121.92,
      "text": "不会去出卖他的"
    },
    {
      "start": 4121.92,
      "end": 4123.12,
      "text": "也必须要下这个本"
