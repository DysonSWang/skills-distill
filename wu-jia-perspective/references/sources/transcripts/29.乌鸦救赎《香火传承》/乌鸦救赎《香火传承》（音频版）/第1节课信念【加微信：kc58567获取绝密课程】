    {
      "start": 4198.400000000001,
      "end": 4199.04,
      "text": "我甩不出去"
    },
    {
      "start": 4199.04,
      "end": 4200.8,
      "text": "我没有办法做到心安理得"
    },
    {
      "start": 4200.8,
      "end": 4202.240000000001,
      "text": "我总觉得老爸就得干点活"
