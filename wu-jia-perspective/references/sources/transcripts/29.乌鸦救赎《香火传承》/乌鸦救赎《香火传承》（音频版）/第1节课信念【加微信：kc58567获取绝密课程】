    {
      "start": 4099.28,
      "end": 4100.64,
      "text": "司机拿个司机的钱"
    },
    {
      "start": 4100.64,
      "end": 4101.68,
      "text": "快捷拿个快捷的钱"
    },
    {
      "start": 4101.68,
      "end": 4102.72,
      "text": "这里面还有这么多的事"
    },
    {
      "start": 4102.72,
      "end": 4105.44,
      "text": "还得过年过节还得给人家父母发红包"
