    {
      "start": 4446.360000000001,
      "end": 4447.660000000001,
      "text": "而且你的手艺"
    },
    {
      "start": 4447.96,
      "end": 4448.96,
      "text": "确实啊"
    },
    {
      "start": 4448.96,
      "end": 4450.36,
      "text": "确实很牛逼的时候"
    },
    {
      "start": 4450.56,
      "end": 4452.06,
      "text": "你这个时候就会需要另外一种东西"
    },
    {
      "start": 4452.06,
      "end": 4453.46,
      "text": "他叫做经营技术"
    },
    {
      "start": 4453.56,
      "end": 4454.26,
      "text": "对不对"
    },
    {
      "start": 4454.26,
      "end": 4455.46,
      "text": "牛文局一个简单例子"
    },
    {
      "start": 4455.46,
      "end": 4456.66,
      "text": "我爸那个诊所"
    },
    {
      "start": 4456.66,
      "end": 4457.46,
      "text": "我就觉得他"
    },
    {
      "start": 4457.46,
      "end": 4459.06,
      "text": "他们的挺不误政业"
    },
    {
      "start": 4459.06,
      "end": 4461.16,
      "text": "因为他他没有太强的生存危机"
    },
    {
      "start": 4461.36,
      "end": 4462.86,
      "text": "他自己大概有一个八九千"
    },
    {
      "start": 4462.86,
      "end": 4464.26,
      "text": "今天上万块钱的一个退休工资"
    },
    {
      "start": 4464.26,
      "end": 4464.56,
      "text": "你知道吗"
    },
    {
      "start": 4464.56,
      "end": 4466.06,
      "text": "老是不好好干自己这行"
    },
    {
      "start": 4466.06,
      "end": 4468.26,
      "text": "每天没事干就是出去喝酒打架"
