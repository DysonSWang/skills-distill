    {
      "start": 4440.660000000001,
      "end": 4441.660000000001,
      "text": "人脉呀"
    },
    {
      "start": 4441.660000000001,
      "end": 4443.06,
      "text": "这些你不用去考虑"
    },
    {
      "start": 4443.06,
      "end": 4443.76,
      "text": "我告诉你"
    },
    {
      "start": 4443.860000000001,
      "end": 4446.360000000001,
      "text": "当你一旦有了一种技术产生之后"
