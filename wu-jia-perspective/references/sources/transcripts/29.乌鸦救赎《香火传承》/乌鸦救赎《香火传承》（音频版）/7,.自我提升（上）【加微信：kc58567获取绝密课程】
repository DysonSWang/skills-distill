    {
      "start": 4488.96,
      "end": 4489.76,
      "text": "越往开"
    },
    {
      "start": 4489.76,
      "end": 4491.26,
      "text": "最后干脆开到村子里面去了"
    },
    {
      "start": 4491.66,
      "end": 4492.06,
      "text": "但是呢"
    },
    {
      "start": 4492.06,
      "end": 4493.66,
      "text": "我在他的朋友当中"
    },
    {
      "start": 4493.66,
      "end": 4495.66,
      "text": "我看到过有很多医生"
    },
    {
      "start": 4495.66,
      "end": 4497.56,
      "text": "人家就是把自己的规模做大"
    },
    {
      "start": 4497.96,
      "end": 4499.16,
      "text": "拉上自己的亲戚"
    },
    {
      "start": 4499.16,
      "end": 4500.46,
      "text": "拉上自己的儿媳妇"
    },
    {
      "start": 4500.46,
      "end": 4501.56,
      "text": "等等职类各种手段"
    },
    {
      "start": 4501.56,
      "end": 4502.56,
      "text": "去把这个生意做大"
    },
    {
      "start": 4502.96,
      "end": 4504.16,
      "text": "人家一个小门诊"
    },
    {
      "start": 4504.16,
      "end": 4506.36,
      "text": "干了出来翻层的一个楼那么大"
    },
    {
      "start": 4506.36,
      "end": 4507.46,
      "text": "而且是自己盖的"
    },
    {
      "start": 4507.46,
      "end": 4507.96,
      "text": "你知道吗"
    },
    {
      "start": 4507.96,
      "end": 4510.16,
      "text": "就是像我知道他有一个看癫痺病的"
    },
    {
      "start": 4510.56,
      "end": 4510.76,
      "text": "对吧"
    },
    {
      "start": 4510.76,
      "end": 4512.76,
      "text": "然后还有一个就是我的同学"
    },
    {
      "start": 4512.76,
      "end": 4514.16,
      "text": "我的同学他的这个"
    },
    {
      "start": 4514.36,
      "end": 4515.26,
      "text": "我同学是女生"
    },
    {
      "start": 4515.26,
      "end": 4517.26,
      "text": "然后嫁给了我的另外一个同学"
    },
    {
      "start": 4517.26,
      "end": 4518.96,
      "text": "他爸爸是一个搞那个什么"
    },
    {
      "start": 4519.06,
      "end": 4520.06,
      "text": "搞那个疯子病"
    },
    {
      "start": 4520.06,
      "end": 4521.56,
      "text": "就看疯子病是一决"
    },
    {
      "start": 4522.56,
      "end": 4523.66,
      "text": "那个够夸张"
    },
    {
      "start": 4523.66,
      "end": 4526.36,
      "text": "我觉得他已经顶得住一个私人的"
    },
    {
      "start": 4526.36,
      "end": 4528.46,
      "text": "一个就是小型的医院了"
    },
    {
      "start": 4528.66,
      "end": 4529.96,
      "text": "就是大概五六层楼吧"
