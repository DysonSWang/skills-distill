    {
      "start": 188.68,
      "end": 191.02,
      "text": "你觉得自己做这些事情你毫无意义"
    },
    {
      "start": 191.02,
      "end": 192.18,
      "text": "你觉得自己刷课也好"
    },
    {
      "start": 192.18,
      "end": 192.92000000000002,
      "text": "刷资源也好"
    },
    {
      "start": 192.92000000000002,
      "end": 193.48000000000002,
      "text": "聊天也好"
    },
    {
      "start": 193.48000000000002,
      "end": 194.38000000000002,
      "text": "没有任何意义了"
