      "text": "以你們牽手"
    },
    {
      "start": 825.44,
      "end": 825.84,
      "text": "接吻"
    },
    {
      "start": 825.84,
      "end": 826.5600000000001,
      "text": "打K"
    },
    {
      "start": 826.6400000000001,
      "end": 828.24,
      "text": "並且一起就是"
    },
    {
      "start": 828.24,
      "end": 830.1600000000001,
      "text": "就包括有一個很敏感的話題"
    },
    {
      "start": 830.1600000000001,
      "end": 831.6800000000001,
      "text": "就是你怎麼樣去讓女孩"
    },
    {
      "start": 831.6800000000001,
      "end": 832.8000000000001,
      "text": "就是今天晚上別走"
    },
    {
      "start": 832.8000000000001,
      "end": 833.5200000000001,
      "text": "留下來陪你"
    },
    {
      "start": 835.84,
      "end": 836.8800000000001,
      "text": "一次睜眼"
    },
    {
      "start": 836.8800000000001,
      "end": 837.7600000000001,
      "text": "厚臉皮"
    },
    {
      "start": 837.7600000000001,
      "end": 838.48,
      "text": "一次睜眼"
    },
    {
      "start": 839.12,
      "end": 840.6400000000001,
      "text": "膽大心細臉皮厚"
    },
    {
      "start": 840.6400000000001,
      "end": 841.7600000000001,
      "text": "這個裡面厚最重要"
    },
    {
      "start": 842.8800000000001,
      "end": 844.32,
      "text": "就記住你要把那種"
    },
    {
      "start": 844.32,
      "end": 845.6800000000001,
      "text": "大姐姐操作那種"
    },
    {
      "start": 845.6800000000001,
      "end": 848.24,
      "text": "小男孩的那種氣勢給拿出來"
    },
    {
      "start": 848.24,
      "end": 849.36,
      "text": "你是爺們"
    },
    {
      "start": 849.36,
      "end": 851.7600000000001,
      "text": "你看我教你們這幫爺們的時候"
    },
    {
      "start": 851.7600000000001,
      "end": 853.5200000000001,
      "text": "我還要拿大姐姐舉例子"
    },
    {
      "start": 853.5200000000001,
      "end": 855.0400000000001,
      "text": "你覺得你們是不是爺們"
    },
    {
      "start": 855.0400000000001,
      "end": 855.36,
      "text": "就是"
    },
    {
      "start": 856.16,
      "end": 856.96,
      "text": "懂嗎"
    },
    {
      "start": 856.96,
      "end": 858.4,
      "text": "懂我下麵的意思就行"
    },
    {
      "start": 858.4,
      "end": 859.2,
      "text": "對不對"
    },
    {
      "start": 859.2,
      "end": 859.52,
      "text": "OK"
    },
    {
      "start": 859.52,
      "end": 861.28,
      "text": "那整個天日的補充我就"
    },
    {
      "start": 861.92,
      "end": 863.04,
      "text": "給到大家了"
    },
    {
      "start": 863.04,
      "end": 863.92,
      "text": "給到大家了"
    },
    {
      "start": 863.92,
      "end": 865.92,
      "text": "那我在這裡的話"
    },
    {
      "start": 866.5600000000001,
      "end": 866.88,
      "text": "算了"
    },
    {
      "start": 866.88,
      "end": 868.32,
      "text": "我下一個視頻"
    },
    {
      "start": 868.32,
      "end": 869.6800000000001,
      "text": "再跟大家單獨講這個點"
    },
    {
      "start": 869.6800000000001,
      "end": 870.72,
      "text": "拜拜"
    }
  ]
}