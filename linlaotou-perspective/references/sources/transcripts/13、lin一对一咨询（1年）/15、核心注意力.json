    },
    {
      "start": 651.24,
      "end": 652.84,
      "text": "好那得搞了你死定了"
    },
    {
      "start": 652.84,
      "end": 653.5600000000001,
      "text": "为什么"
    },
    {
      "start": 653.5600000000001,
      "end": 656.0400000000001,
      "text": "因为你考虑的问题是不现实的"
    },
    {
      "start": 656.76,
      "end": 657.64,
      "text": "我们要说什么呢"
    },
    {
      "start": 657.64,
      "end": 658.6800000000001,
      "text": "人要有格局"
    },
    {
      "start": 660.12,
      "end": 661.64,
      "text": "但有格局的前提是什么呢"
    },
    {
      "start": 661.64,
      "end": 662.12,
      "text": "要落地"
    },
    {
      "start": 662.84,
      "end": 663.24,
      "text": "要落地"
    },
    {
      "start": 663.24,
      "end": 664.36,
      "text": "要像很多司教过来"
    },
    {
      "start": 664.36,
      "end": 665.5600000000001,
      "text": "他想问我的话是什么呢"
    },
    {
      "start": 665.5600000000001,
      "end": 667.5600000000001,
      "text": "就是我一下子快速拿到结果"
    },
    {
      "start": 669.08,
      "end": 670.0400000000001,
      "text": "这不现实"
    },
    {
      "start": 670.0400000000001,
      "end": 671.32,
      "text": "你要考虑你自己的情况"
    },
    {
      "start": 671.32,
      "end": 672.28,
      "text": "考虑你自己的情"
    },
    {
      "start": 673.32,
      "end": 675.24,
      "text": "目前的收入"
    },
    {
      "start": 675.24,
      "end": 675.72,
      "text": "颜值"
    },
    {
      "start": 676.52,
      "end": 676.9200000000001,
      "text": "情商"
    },
    {
      "start": 677.48,
      "end": 678.76,
      "text": "对旅人的了解"
    },
    {
      "start": 678.76,
      "end": 682.52,
      "text": "去以你现在的情况为基准"
    },
    {
      "start": 683.48,
      "end": 684.2,
      "text": "去往后发展"
    },
    {
      "start": 685.3199999999999,
      "end": 687.0,
      "text": "就是在你现在的速度"
    },
    {
      "start": 687.0,
      "end": 689.72,
      "text": "就现在的一个格局里最快的速度去发展"
    },
    {
      "start": 689.72,
      "end": 691.64,
      "text": "所以说我们回到核心来讲什么呢"
    },
    {
      "start": 691.64,
      "end": 693.64,
      "text": "就是战略要远大"
    },
    {
      "start": 693.64,
      "end": 695.64,
      "text": "但是战术一定要落地"
    },
    {
      "start": 695.64,
      "end": 698.76,
      "text": "战略上我们可以把别人全部旅人当成傻逼"
    },
    {
      "start": 698.76,
      "end": 699.96,
      "text": "但是我们在战术上"
    },
    {
      "start": 699.96,
      "end": 701.0,
      "text": "在实际聊天中"
    },
    {
      "start": 701.0,
      "end": 702.92,
      "text": "我们要把每一个旅人当成我们的老师"
    },
    {
      "start": 702.92,
      "end": 704.2,
      "text": "当成他们靠谱的旅人"
    },
    {
      "start": 704.76,
      "end": 706.4399999999999,
      "text": "而不是去怀疑这怀疑那"
    },
    {
      "start": 706.4399999999999,
      "end": 707.64,
      "text": "核心注意力放在哪里"
    },
    {
      "start": 709.16,
      "end": 710.36,
      "text": "还是这个无关键的问题"
    },
    {
      "start": 711.0,
      "end": 711.96,
      "text": "今天就讲到这里"
    },
    {
      "start": 713.8,
      "end": 714.2,
      "text": "拜拜"
    }
  ]
}