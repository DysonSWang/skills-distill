    {
      "start": 388.0,
      "end": 389.0,
      "text": "就是比如说"
    },
    {
      "start": 390.0,
      "end": 393.0,
      "text": "你实际经历了一个完整的聊天"
    },
    {
      "start": 393.0,
      "end": 394.0,
      "text": "你拿到过一个结果"
    },
    {
      "start": 394.0,
      "end": 395.0,
      "text": "有女生对你很认可"
