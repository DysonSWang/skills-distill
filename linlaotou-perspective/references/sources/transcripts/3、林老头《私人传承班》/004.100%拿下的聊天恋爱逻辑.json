      "end": 604.2,
      "text": "对吧"
    },
    {
      "start": 604.2,
      "end": 605.2,
      "text": "很多人担心一些去洗了"
    },
    {
      "start": 605.2,
      "end": 606.2,
      "text": "有代表的每个"
    },
    {
      "start": 606.2,
      "end": 607.2,
      "text": "对吧"
    },
    {
      "start": 607.2,
      "end": 608.2,
      "text": "都可以跳脱出声高"
    },
    {
      "start": 608.2,
      "end": 609.2,
      "text": "这个问题来解决"
    },
    {
      "start": 609.2,
      "end": 610.2,
      "text": "就不要说"
    },
    {
      "start": 610.2,
      "end": 611.2,
      "text": "你真的喜欢一个人"
    },
    {
      "start": 611.2,
      "end": 612.2,
      "text": "什么会在我声高的"
    },
    {
      "start": 612.2,
      "end": 613.2,
      "text": "这个是不是很确的"
    },
    {
      "start": 613.2,
      "end": 614.2,
      "text": "但那么女人性"
    },
    {
      "start": 614.2,
      "end": 616.2,
      "text": "那比如说"
    },
    {
      "start": 616.2,
      "end": 618.2,
      "text": "有的人很在乎"
    },
    {
      "start": 618.2,
      "end": 619.2,
      "text": "就是关系理"
    },
    {
      "start": 619.2,
      "end": 620.2,
      "text": "女生要被动"
    },
    {
      "start": 620.2,
      "end": 622.2,
      "text": "真的喜欢一个人"
    },
    {
      "start": 622.2,
      "end": 624.2,
      "text": "他妈的亏异之被动"
    },
    {
      "start": 624.2,
      "end": 625.1600000000001,
      "text": "亏异之不给你"
    },
    {
      "start": 625.16,
      "end": 626.16,
      "text": "对吧"
    },
    {
      "start": 626.16,
      "end": 628.16,
      "text": "你不能在问题体系解认问题"
    },
    {
      "start": 628.16,
      "end": 629.16,
      "text": "但这个我就不在这里"
    },
    {
      "start": 629.16,
      "end": 630.16,
      "text": "过多说了"
    },
    {
      "start": 630.16,
      "end": 631.16,
      "text": "就简单地讲一讲"
    },
    {
      "start": 631.16,
      "end": 633.16,
      "text": "关于最后理想要去"
    },
    {
      "start": 633.16,
      "end": 635.16,
      "text": "建立一段关系的一些众源"
    },
    {
      "start": 635.16,
      "end": 636.16,
      "text": "好了"
    },
    {
      "start": 636.16,
      "end": 637.16,
      "text": "大家千万不要把自己放在"
    },
    {
      "start": 637.16,
      "end": 639.16,
      "text": "填骨的一个心态里"
    },
    {
      "start": 639.16,
      "end": 641.16,
      "text": "就是我很悲为众心态里"
    },
    {
      "start": 641.16,
      "end": 643.16,
      "text": "我不希望大家在这种心态里去过火"
    },
    {
      "start": 643.16,
      "end": 644.16,
      "text": "好吧"
    },
    {
      "start": 644.16,
      "end": 645.16,
      "text": "众源是走心生真"
    },
    {
      "start": 645.16,
      "end": 648.16,
      "text": "就理自己的必须"
    },
    {
      "start": 648.16,
      "end": 650.16,
      "text": "哪怕你骗自己"
    },
    {
      "start": 650.16,
      "end": 652.16,
      "text": "你就得把自己骗得很走心"
    },
    {
      "start": 652.16,
      "end": 653.16,
      "text": "但是"
    },
    {
      "start": 653.16,
      "end": 655.16,
      "text": "你要随身能够抽一出来"
    },
    {
      "start": 655.16,
      "end": 656.16,
      "text": "为什么"
    },
    {
      "start": 656.16,
      "end": 658.16,
      "text": "因为你下面你要给自己设计"
    },
    {
      "start": 658.16,
      "end": 660.16,
      "text": "金干滚"
    },
    {
      "start": 660.16,
      "end": 662.16,
      "text": "就可以帮助理抽一抽"
    },
    {
      "start": 662.16,
      "end": 664.16,
      "text": "因为如果理不得一个傻皮的人"
    },
    {
      "start": 664.16,
      "end": 666.16,
      "text": "你抽一不出来你就记了"
    },
    {
      "start": 666.16,
      "end": 667.16,
      "text": "好了"
    },
    {
      "start": 667.16,
      "end": 668.16,
      "text": "OK"
    },
    {
      "start": 668.16,
      "end": 669.16,
      "text": "就算就好了"
    }
  ]
}