    },
    {
      "start": 127.0,
      "end": 129.0,
      "text": "其實都可以有機會跟莊老師挖寶"
    },
    {
      "start": 129.0,
      "end": 131.0,
      "text": "上一次第五場"
    },
    {
      "start": 131.0,
      "end": 133.0,
      "text": "後面有人在敲碗問說"
    },
    {
      "start": 133.0,
      "end": 137.0,
