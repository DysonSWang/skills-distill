    {
      "start": 570.82,
      "end": 572.82,
      "text": "就看嘛"
    },
    {
      "start": 572.82,
      "end": 574.82,
      "text": "你過這麼爽"
    },
    {
      "start": 574.82,
      "end": 576.82,
      "text": "會跟著你這樣跟下去"
    },
    {
      "start": 576.82,
      "end": 578.82,
      "text": "也會爽到我啊"
    },
    {
      "start": 578.82,
      "end": 580.82,
      "text": "但大屏要兌現"
    },
    {
      "start": 580.82,
      "end": 582.82,
      "text": "這個我要跟大家特別強調"
    },
    {
      "start": 582.82,
      "end": 584.82,
      "text": "看起來蠻多人都有"
    },
    {
      "start": 584.82,
      "end": 586.82,
      "text": "提到這件事情"
    },
    {
      "start": 586.82,
      "end": 588.82,
      "text": "那我就要來把答案"
    },
    {
      "start": 590.82,
      "end": 592.82,
      "text": "再往下講"
    },
    {
      "start": 592.82,
      "end": 594.82,
      "text": "把這個背呢"
    },
    {
      "start": 598.82,
      "end": 600.82,
      "text": "這個啊"
    },
    {
      "start": 600.82,
      "end": 602.82,
      "text": "虛擬大屏"
    },
    {
      "start": 602.82,
      "end": 604.82,
      "text": "這個情況是老闆"
    },
    {
      "start": 604.82,
      "end": 606.82,
      "text": "有機會讓員工"
    },
    {
      "start": 606.82,
      "end": 608.82,
      "text": "腦補各種各式各樣虛擬大屏的類型"
    },
    {
      "start": 608.82,
      "end": 610.82,
      "text": "第一個"
    },
    {
      "start": 610.82,
      "end": 612.82,
      "text": "就講雄才大略"
    },
    {
      "start": 612.82,
      "end": 614.82,
      "text": "你老闆很厲害"
    },
    {
      "start": 614.82,
      "end": 616.82,
      "text": "你老闆的手腕漂亮"
    },
    {
      "start": 616.82,
      "end": 618.82,
      "text": "有能力"
    },
    {
      "start": 618.82,
      "end": 620.82,
      "text": "錢也很多"
    },
    {
      "start": 620.82,
      "end": 622.82,
      "text": "跟著他混一定有前途"
    },
    {
      "start": 622.82,
      "end": 624.82,
      "text": "你會這樣跟自己說"
    },
    {
      "start": 624.82,
      "end": 626.82,
      "text": "包含你們剛剛講的人格魅力"
    },
    {
      "start": 626.82,
      "end": 628.82,
      "text": "也是有的"
    },
    {
      "start": 628.82,
      "end": 630.82,
      "text": "OK"
    },
    {
      "start": 630.82,
      "end": 632.82,
      "text": "就是有人提到這件事情"
    },
    {
      "start": 632.82,
      "end": 634.82,
      "text": "公司業績好"
    },
    {
      "start": 634.82,
      "end": 636.82,
      "text": "未來有發展空間"
    },
    {
      "start": 636.82,
      "end": 638.82,
      "text": "就是我們這邊要講的"
    },
    {
      "start": 640.82,
      "end": 642.82,
      "text": "先都秀一秀"
    },
    {
      "start": 642.82,
      "end": 644.82,
      "text": "公司成長"
    },
    {
      "start": 644.82,
      "end": 646.82,
      "text": "公司的規矩跟"
    },
    {
      "start": 646.82,
      "end": 648.82,
      "text": "格局跟規模真的是"
    },
    {
      "start": 648.82,
      "end": 650.82,
      "text": "越來越大"
    },
    {
      "start": 650.82,
      "end": 652.82,
      "text": "就是公司業績好"
    },
    {
      "start": 652.82,
      "end": 654.82,
      "text": "公司有沒有錢"
    },
    {
      "start": 654.82,
      "end": 656.82,
      "text": "你自己都會知道"
    },
    {
      "start": 656.82,
      "end": 658.82,
      "text": "第二個是有人吃到餅"
    },
    {
      "start": 658.82,
      "end": 660.82,
      "text": "可能真的因為在那邊"
    },
    {
      "start": 660.82,
      "end": 662.82,
      "text": "待著"
    },
    {
      "start": 662.82,
      "end": 664.82,
      "text": "老闆有把餅分給他"
    },
    {
      "start": 664.82,
      "end": 666.82,
      "text": "他有升遷了"
    },
    {
      "start": 666.82,
      "end": 668.82,
      "text": "他因此而升遷了"
    },
    {
      "start": 668.82,
      "end": 670.82,
      "text": "只要這個同事不是老闆的親戚"
    },
    {
      "start": 670.82,
      "end": 672.82,
      "text": "不是什麼他媽的突然間"
    },
    {
      "start": 672.82,
      "end": 674.82,
      "text": "海外歸國的"
    },
    {
      "start": 674.82,
      "end": 676.82,
      "text": "富二代兒子"
    },
    {
      "start": 676.82,
      "end": 678.82,
      "text": "也是靠實力打上去的"
    },
    {
      "start": 678.82,
      "end": 680.82,
      "text": "有別人吃到餅"
    },
    {
      "start": 680.82,
      "end": 682.82,
      "text": "你就跟自己說"
    },
    {
      "start": 682.82,
      "end": 684.82,
      "text": "只要我努力幹"
    },
    {
      "start": 684.82,
      "end": 686.82,
      "text": "我一定能夠跟我的同事一樣"
    },
    {
      "start": 686.82,
      "end": 688.82,
      "text": "我吃到這個包含加薪"
    },
    {
      "start": 688.82,
      "end": 690.82,
      "text": "獎金"
    },
    {
      "start": 690.82,
      "end": 692.82,
      "text": "這種餅"
    },
    {
      "start": 692.82,
      "end": 694.82,
      "text": "所以這三個是我歸納出來的"
    },
    {
      "start": 694.82,
      "end": 696.82,
      "text": "虛擬大餅的"
    },
    {
      "start": 696.82,
      "end": 698.82,
      "text": "呈現方式"
    },
    {
      "start": 700.82,
      "end": 702.82,
      "text": "那麼我跟大家說的這個"
    },
    {
      "start": 702.82,
      "end": 704.82,
      "text": "對創業者而言"
    },
    {
      "start": 704.82,
      "end": 706.82,
      "text": "畫大餅有其必要"
    },
    {
      "start": 706.82,
      "end": 708.82,
      "text": "但是能不能夠兌現大餅"
    },
    {
      "start": 708.82,
      "end": 710.82,
      "text": "才是減和創業者的"
    },
    {
      "start": 710.82,
      "end": 712.82,
      "text": "重要指標"
    },
    {
      "start": 712.82,
      "end": 714.82,
      "text": "今天劉備如果他永遠都"
    },
    {
      "start": 714.82,
      "end": 716.82,
      "text": "一座城池這樣子混"
    },
    {
      "start": 716.82,
      "end": 718.82,
      "text": "我記得我以前玩那三國志遊戲"
    },
    {
      "start": 718.82,
      "end": 720.82,
      "text": "劉備到中期"
    },
    {
      "start": 720.82,
      "end": 722.82,
      "text": "到打完赤壁"
    },
    {
      "start": 722.82,
      "end": 724.82,
      "text": "才有了相當的土地跟"
    },
    {
      "start": 724.82,
      "end": 726.82,
      "text": "孫璇跟曹操在那邊拼"
    },
    {
      "start": 726.82,
      "end": 728.82,
      "text": "在那之前都是"
    },
    {
      "start": 728.82,
      "end": 730.82,
      "text": "曹操很大一片"
    },
    {
      "start": 730.82,
      "end": 732.82,
      "text": "孫璇也是蠻大一片的"
    },
    {
      "start": 732.82,
      "end": 734.82,
      "text": "劉備就一小塊"
    },
    {
      "start": 734.82,
      "end": 736.82,
      "text": "但他不能永遠都這個樣子"
    },
    {
      "start": 736.82,
      "end": 738.82,
      "text": "他一定要能夠成長"
    },
    {
      "start": 738.82,
      "end": 740.82,
      "text": "他的地、人才、規模"
    },
    {
      "start": 740.82,
      "end": 742.82,
      "text": "一定要慢慢的往上成長"
    },
    {
      "start": 742.82,
      "end": 744.82,
      "text": "你員工才會有信心"
    },
    {
      "start": 744.82,
      "end": 746.82,
      "text": "你員工才會有信心"
    },
    {
      "start": 746.82,
      "end": 748.82,
      "text": "去繼續跟你混"
    },
    {
      "start": 748.82,
      "end": 750.82,
      "text": "他們要先吃飽"
    },
    {
      "start": 750.82,
      "end": 752.82,
      "text": "然後吃飽才能夠"
    },
    {
      "start": 752.82,
      "end": 754.82,
      "text": "有那個能力跟你"
    },
    {
      "start": 754.82,
      "end": 756.82,
      "text": "繼續這樣子混下去"
    },
    {
      "start": 756.82,
      "end": 758.82,
      "text": "所以你要觀察老闆"
    },
    {
      "start": 758.82,
      "end": 760.82,
      "text": "當他在畫大餅的時候"
    },
    {
      "start": 760.82,
      "end": 762.82,
      "text": "你要去看他是不是"
    },
    {
      "start": 762.82,
      "end": 764.82,
      "text": "有兌現"
    },
    {
      "start": 764.82,
      "end": 766.82,
      "text": "那這件事情"
    },
    {
      "start": 766.82,
      "end": 768.82,
      "text": "你可以透過跟他的員工"
    },
    {
      "start": 768.82,
      "end": 770.82,
      "text": "聊天然後跟他的"
    },
    {
      "start": 770.82,
      "end": 772.82,
      "text": "老闆聊天兩個"
    },
    {
      "start": 772.82,
      "end": 774.82,
      "text": "去對照就知道"
    },
    {
      "start": 774.82,
      "end": 776.82,
      "text": "大餅畫出來有沒有兌現"
    },
    {
      "start": 776.82,
      "end": 778.82,
      "text": "畫了一堆有兌現過嗎"
    },
    {
      "start": 778.82,
      "end": 780.82,
      "text": "這個你要去觀察"
    },
    {
      "start": 780.82,
      "end": 782.82,
      "text": "另外你要去想"
    },
    {
      "start": 782.82,
      "end": 784.82,
      "text": "如果別人吃到餅了"
    },
    {
      "start": 784.82,
      "end": 786.82,
      "text": "但這個餅"
    },
    {
      "start": 786.82,
      "end": 788.82,
      "text": "會不會輪到我身上"
    },
    {
      "start": 788.82,
      "end": 790.82,
      "text": "也就是說"
    },
    {
      "start": 790.82,
      "end": 792.82,
      "text": "如果今天這個老闆"
    },
    {
      "start": 792.82,
      "end": 794.82,
      "text": "他真的一直提拔"
    },
    {
      "start": 794.82,
      "end": 796.82,
      "text": "這個員工"
    },
    {
      "start": 796.82,
      "end": 798.82,
      "text": "你可能很前期認為老闆都有把"
    },
    {
      "start": 798.82,
      "end": 800.82,
      "text": "你的餅分給你的同事"
    },
    {
      "start": 800.82,
      "end": 802.82,
      "text": "可是好像"
    },
    {
      "start": 802.82,
      "end": 804.82,
      "text": "很奇怪好像我在做"
    },
    {
      "start": 804.82,
      "end": 806.82,
      "text": "我做在努力"
    },
    {
      "start": 806.82,
      "end": 808.82,
      "text": "老闆就是不會把獎勵分"
    },
    {
      "start": 808.82,
      "end": 810.82,
      "text": "到我這邊我比一比幹我他媽"
    },
    {
      "start": 810.82,
      "end": 812.82,
      "text": "就是比他厲害多了"
    },
    {
      "start": 812.82,
      "end": 814.82,
      "text": "就是不會把餅分到我這邊"
    },
    {
      "start": 814.82,
      "end": 816.82,
      "text": "那你就"
    },
    {
      "start": 816.82,
      "end": 818.82,
      "text": "小心了通常這件事情"
    },
    {
      "start": 818.82,
      "end": 820.82,
      "text": "你跟員工聊天聊久了"
    },
    {
      "start": 820.82,
      "end": 822.82,
      "text": "有些會抱怨"
    },
    {
      "start": 822.82,
      "end": 824.82,
      "text": "有些會抱怨這種東西"
    },
    {
      "start": 824.82,
      "end": 826.82,
      "text": "另外一個則是"
    },
    {
      "start": 826.82,
      "end": 828.82,
      "text": "公司的業績雖然有成長"
    },
    {
      "start": 828.82,
      "end": 830.82,
      "text": "但是你的薪水"
    },
    {
      "start": 830.82,
      "end": 832.82,
      "text": "或是員工的薪水"
    },
    {
      "start": 832.82,
      "end": 836.82,
      "text": "有因此而變多嗎"
    },
    {
      "start": 836.82,
      "end": 838.82,
      "text": "對不對"
    },
    {
      "start": 838.82,
      "end": 840.82,
      "text": "公司的確成長了"
    },
    {
      "start": 840.82,
      "end": 842.82,
      "text": "但是他有沒有把這個利潤分給員工"
    },
    {
      "start": 842.82,
      "end": 844.82,
      "text": "你說他可能一時半刻"
    },
    {
      "start": 844.82,
      "end": 846.82,
      "text": "是想要把它拿來做再投資"
    },
    {
      "start": 846.82,
      "end": 848.82,
      "text": "就拿來投資做研發"
    },
    {
      "start": 848.82,
      "end": 850.82,
      "text": "提升那個產品規模"
    },
    {
      "start": 850.82,
      "end": 852.82,
      "text": "都有可能去研發技術"
    },
    {
      "start": 852.82,
      "end": 854.82,
      "text": "但還是要多分一點給員工"
    },
    {
      "start": 854.82,
      "end": 856.82,
      "text": "不論怎麼樣都是要多"
    },
    {
      "start": 856.82,
      "end": 858.82,
      "text": "多多少是一回事"
    },
    {
      "start": 858.82,
      "end": 860.82,
      "text": "你不能夠永遠是那個樣子"
    },
    {
      "start": 860.82,
      "end": 862.82,
      "text": "所以"
    },
    {
      "start": 862.82,
      "end": 864.82,
      "text": "這三個是你要去觀察"
    },
    {
      "start": 864.82,
      "end": 866.82,
      "text": "這個老闆他在畫大餅的時候"
    },
    {
      "start": 866.82,
      "end": 868.82,
      "text": "是有沒有去兌現的"
    },
    {
      "start": 868.82,
      "end": 870.82,
      "text": "同樣的你該的公司"
    },
    {
      "start": 870.82,
      "end": 872.82,
      "text": "你的老闆他在畫大餅的時候"
    },
    {
      "start": 872.82,
      "end": 874.82,
      "text": "有沒有去把這東西"
    },
    {
      "start": 874.82,
      "end": 876.82,
      "text": "給兌現"
    },
    {
      "start": 876.82,
      "end": 878.82,
      "text": "當然前提是你要有價值"
    },
    {
      "start": 878.82,
      "end": 880.82,
      "text": "你不能是個廢物你是廢物的話"
    },
    {
      "start": 880.82,
      "end": 882.82,
      "text": "餅弄不到你誰會"
    },
    {
      "start": 882.82,
      "end": 884.82,
      "text": "給廢物吃餅"
    },
    {
      "start": 884.82,
