    {
      "start": 1164.2800000000002,
      "end": 1166.0400000000002,
      "text": "是廢物跟騙子"
    },
    {
      "start": 1166.0400000000002,
      "end": 1167.5200000000002,
      "text": "而且機率還不低"
    },
    {
      "start": 1168.72,
      "end": 1169.8400000000001,
      "text": "然後不瞞各位"
    },
    {
      "start": 1169.8400000000001,
      "end": 1171.16,
      "text": "李子歌之前"
    },
    {
      "start": 1171.16,
      "end": 1172.72,
      "text": "很常看我的直播"
    },
    {
      "start": 1173.72,
      "end": 1175.8,
      "text": "所以這個東西他成立"
    },
    {
      "start": 1175.8,
      "end": 1178.96,
      "text": "所以他應該是把我當一回事"
    },
    {
      "start": 1178.96,
      "end": 1180.72,
      "text": "還好我解套了"
    },
    {
      "start": 1183.2,
      "end": 1184.84,
      "text": "我解套了"
    },
    {
      "start": 1184.84,
      "end": 1186.3600000000001,
      "text": "我非常確定"
    },
    {
      "start": 1186.3600000000001,
      "end": 1188.24,
      "text": "我非常確定李子歌到後期"
    },
    {
      "start": 1188.24,
      "end": 1190.4,
      "text": "就沒有再看我的直播了"
    },
    {
      "start": 1190.4,
      "end": 1192.16,
      "text": "然後也沒有要跟我互動"
    },
    {
      "start": 1192.16,
      "end": 1193.88,
      "text": "所以我花了一些功夫"
    },
    {
      "start": 1193.88,
      "end": 1196.24,
      "text": "來做到這件事情"
    },
    {
      "start": 1196.24,
      "end": 1197.92,
      "text": "這個等一下會跟大家說"
    },
    {
      "start": 1197.92,
      "end": 1199.56,
      "text": "所以重點提醒一下"
    },
    {
      "start": 1201.24,
      "end": 1202.3600000000001,
      "text": "來"
    },
    {
      "start": 1202.5200000000002,
      "end": 1204.72,
      "text": "多方何時不同領域"
    },
    {
      "start": 1204.72,
      "end": 1206.48,
      "text": "然後去逼近真相"
    },
    {
      "start": 1206.48,
      "end": 1207.7600000000002,
      "text": "逼近什麼真相呢"
    },
    {
      "start": 1207.7600000000002,
      "end": 1210.48,
      "text": "逼近這個人的人格跟他真實實力"
    },
    {
      "start": 1211.2800000000002,
      "end": 1213.2800000000002,
      "text": "那平常就要廣結善緣"
    },
    {
      "start": 1213.2800000000002,
      "end": 1214.96,
      "text": "不然的話你拿來的情報網"
    },
    {
      "start": 1214.96,
      "end": 1216.68,
      "text": "幫你去查核這些事情"
    },
    {
      "start": 1216.68,
      "end": 1217.2,
      "text": "對不對"
    },
    {
      "start": 1217.2,
      "end": 1218.8000000000002,
      "text": "電話一打就能夠解決"
    },
    {
      "start": 1218.8000000000002,
      "end": 1220.44,
      "text": "那很多老闆是電話一打"
    },
    {
      "start": 1220.44,
      "end": 1222.96,
      "text": "這個人的底細就問得一清二楚了"
    },
    {
      "start": 1222.96,
      "end": 1224.96,
      "text": "那我們平常就要去廣結善緣"
    },
    {
      "start": 1224.96,
      "end": 1227.3200000000002,
      "text": "有足夠的專業單位"
    },
    {
      "start": 1227.3200000000002,
      "end": 1229.2800000000002,
      "text": "幫我們去做這些事情"
    },
    {
      "start": 1229.32,
      "end": 1230.04,
      "text": "來"
    },
    {
      "start": 1230.04,
      "end": 1232.28,
      "text": "很可能從何時當中"
    },
    {
      "start": 1232.28,
      "end": 1236.12,
      "text": "去挖出更多嚇死人的黑歷史"
    },
    {
      "start": 1236.12,
      "end": 1237.72,
      "text": "這個有可能"
    },
    {
      "start": 1237.72,
      "end": 1238.68,
      "text": "非常有可能"
    },
    {
      "start": 1239.52,
      "end": 1241.68,
      "text": "然後不會成長的朋友"
    },
    {
      "start": 1241.68,
      "end": 1243.8799999999999,
      "text": "平淡相處勿交"
    },
    {
      "start": 1243.8799999999999,
      "end": 1245.08,
      "text": "不要學我"
    },
    {
      "start": 1245.08,
      "end": 1246.2,
      "text": "不要學我什麼呢"
    },
    {
      "start": 1246.2,
      "end": 1248.08,
      "text": "不要學我像我這樣子"
    },
    {
      "start": 1248.08,
      "end": 1251.08,
      "text": "把他拿來做成課程"
    },
    {
      "start": 1251.08,
      "end": 1252.48,
      "text": "這樣跟大家講"
    }
  ]
}