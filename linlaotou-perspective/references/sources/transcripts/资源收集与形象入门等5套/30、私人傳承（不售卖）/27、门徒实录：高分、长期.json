    {
      "start": 609.4,
      "end": 611.4,
      "text": "我这边还是比较有点欠缺"
    },
    {
      "start": 611.4,
      "end": 613.4,
      "text": "是聊天细节"
    },
    {
      "start": 613.4,
      "end": 615.4,
      "text": "你去拿再拿一瓶酒呗"
