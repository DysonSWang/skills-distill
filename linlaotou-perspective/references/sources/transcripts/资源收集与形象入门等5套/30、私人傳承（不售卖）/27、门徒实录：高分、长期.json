      "text": "回个学院消息"
    },
    {
      "start": 603.4,
      "end": 605.4,
      "text": "刚才说了"
    },
    {
      "start": 605.4,
      "end": 607.4,
      "text": "就是如何和高分那个聊天细节上"
    },
    {
      "start": 607.4,
      "end": 609.4,
      "text": "如果加分"
