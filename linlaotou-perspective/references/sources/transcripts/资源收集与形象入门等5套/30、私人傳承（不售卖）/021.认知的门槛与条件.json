    {
      "start": 769.0,
      "end": 772.0,
      "text": "你不狠下心来去做这件事情"
    },
    {
      "start": 772.0,
      "end": 775.0,
      "text": "你不狠下心来去付出自己的时间"
    },
    {
      "start": 775.0,
      "end": 776.0,
      "text": "精力钱对吧"
