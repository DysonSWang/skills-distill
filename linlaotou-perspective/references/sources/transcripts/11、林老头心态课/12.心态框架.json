    },
    {
      "start": 198.85999999999999,
      "end": 200.39999999999998,
      "text": "其实都不重要"
    },
    {
      "start": 200.39999999999998,
      "end": 201.94,
      "text": "因为那都是过去"
    },
    {
      "start": 201.94,
      "end": 203.72,
      "text": "因为那些东西"
    },
    {
      "start": 203.72,
      "end": 205.26,
      "text": "只是为了"
    },
    {
      "start": 205.26,
      "end": 206.27999999999997,
      "text": "帮助你"
    },
    {
      "start": 206.27999999999997,
      "end": 207.32,
      "text": "提升你自己"
    },
    {
      "start": 207.32,
      "end": 208.33999999999997,
      "text": "而且"
    },
    {
      "start": 208.34,
      "end": 209.88,
      "text": "他已经过去了"
    },
    {
      "start": 209.88,
      "end": 210.9,
      "text": "他发生过"
    },
    {
      "start": 210.9,
      "end": 211.92000000000002,
      "text": "他来过"
    },
    {
      "start": 211.92000000000002,
      "end": 212.94,
      "text": "可是他现在"
    },
    {
      "start": 212.94,
      "end": 214.22,
      "text": "已经不在了"
    },
    {
      "start": 214.22,
      "end": 215.76,
      "text": "所以你要搞清楚"
    },
    {
      "start": 215.76,
      "end": 216.54,
      "text": "你"
    },
    {
      "start": 216.54,
      "end": 218.58,
      "text": "现在要做的事情就是"
    },
    {
      "start": 218.58,
      "end": 220.88,
      "text": "总结你的不好的经历"
    },
    {
      "start": 220.88,
      "end": 222.42000000000002,
      "text": "总结你的失败"
    },
    {
      "start": 222.42000000000002,
      "end": 224.46,
      "text": "总结那些对你不好的人"
    },
    {
      "start": 224.46,
      "end": 226.0,
      "text": "为什么会对你不好"
    },
    {
      "start": 226.0,
      "end": 227.54,
      "text": "去找到为什么"
    },
    {
      "start": 227.54,
      "end": 229.84,
      "text": "去找到这个问题的核心点"
    },
    {
      "start": 229.84,
      "end": 232.14000000000001,
      "text": "然后去解决这个问题"
    },
    {
      "start": 232.14000000000001,
      "end": 233.18,
      "text": "以前我被拒绝"
    },
    {
      "start": 233.18,
      "end": 235.98000000000002,
      "text": "现在我怎么样才能不能不被拒绝"
    },
    {
      "start": 235.98000000000002,
      "end": 237.78,
      "text": "为什么我会被拒绝"
    },
    {
      "start": 237.78,
      "end": 239.06,
      "text": "解决掉这个问题"
    },
    {
      "start": 239.06,
      "end": 242.14000000000001,
      "text": "问题是肯定存在的"
    },
    {
      "start": 242.14000000000001,
      "end": 243.42,
      "text": "而解决问题"
    },
    {
      "start": 243.42,
      "end": 244.7,
      "text": "真是一个男人"
    },
    {
      "start": 244.7,
      "end": 246.22,
      "text": "感觉中的事情"
    },
    {
      "start": 246.22,
      "end": 249.56,
      "text": "所以现在还有什么东西能够影响到你的心态吗"
    },
    {
      "start": 249.56,
      "end": 251.1,
      "text": "没有任何东西了"
    },
    {
      "start": 251.1,
      "end": 252.12,
      "text": "所有的东西"
    },
    {
      "start": 252.12,
      "end": 253.66,
      "text": "只不过是一个反馈"
    },
    {
      "start": 253.66,
      "end": 255.96,
