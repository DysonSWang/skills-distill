    },
    {
      "start": 255.96,
      "end": 257.24,
      "text": "没有任何东西"
    },
    {
      "start": 257.24,
      "end": 258.26,
      "text": "会改变"
    },
    {
      "start": 258.26,
      "end": 260.3,
      "text": "你自己这个人"
    },
    {
      "start": 260.3,
      "end": 261.08,
      "text": "而你"
    },
    {
      "start": 261.08,
      "end": 262.36,
      "text": "自己这个人"
    },
    {
      "start": 262.36,
      "end": 263.9,
      "text": "真正能够改变的"
    },
    {
      "start": 263.9,
      "end": 265.68,
      "text": "往往也就是你自己"
    },
    {
      "start": 265.68,
      "end": 267.22,
      "text": "找到你自己认为"
    },
    {
      "start": 267.22,
      "end": 268.5,
      "text": "真正正确的路"
    },
    {
      "start": 268.5,
      "end": 269.52000000000004,
      "text": "然后去做它"
    },
    {
      "start": 269.52000000000004,
      "end": 270.54,
      "text": "就好了"
    },
    {
      "start": 270.54,
      "end": 272.34000000000003,
      "text": "所有的路上的风景"
    },
    {
      "start": 272.34000000000003,
      "end": 273.62,
      "text": "都只是风景"
    },
    {
      "start": 273.62,
      "end": 275.16,
      "text": "都是在帮助你"
    },
    {
      "start": 275.16,
      "end": 277.98,
      "text": "去过得更好"
    },
    {
      "start": 277.98,
      "end": 280.28000000000003,
      "text": "这就是关于现在的一些想法"
    },
    {
      "start": 280.28000000000003,
      "end": 281.56,
      "text": "那么关于框架"
    },
    {
      "start": 281.56,
      "end": 283.34000000000003,
      "text": "我更建议大家去"
    },
    {
      "start": 283.34000000000003,
      "end": 285.14000000000004,
      "text": "通过实现自我价值"
    },
    {
      "start": 285.14000000000004,
      "end": 286.68,
      "text": "让别人为你主动"
    },
    {
      "start": 286.68,
      "end": 288.22,
      "text": "亮出框架"
    },
    {
      "start": 288.22,
      "end": 290.26000000000005,
      "text": "这一点我其实已经说过了"
    },
    {
      "start": 290.26000000000005,
      "end": 292.06,
      "text": "你可以通过比如说"
    },
    {
      "start": 292.06,
      "end": 294.62,
      "text": "你可以帮助他去做什么事对吧"
    },
    {
      "start": 294.62,
      "end": 297.18,
      "text": "那么什么叫大哥呢大哥就是帮别人"
    },
    {
      "start": 297.22,
      "end": 297.98,
      "text": "做事的人"
    },
    {
      "start": 297.98,
      "end": 299.78000000000003,
      "text": "其实大哥一点都不威风"
    },
    {
      "start": 299.78000000000003,
      "end": 302.08000000000004,
      "text": "大哥的意思就是我帮你解决问题"
