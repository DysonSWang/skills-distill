    {
      "start": 788.28,
      "end": 790.28,
      "text": "那么只能说明这个女生"
    },
    {
      "start": 790.28,
      "end": 791.28,
      "text": "她不是喜欢你"
    },
    {
      "start": 791.28,
      "end": 792.28,
      "text": "她只是想从你身上得到你"
    },
    {
      "start": 792.28,
      "end": 793.28,
      "text": "她只是想从你身上得到你"
    },
    {
      "start": 793.28,
      "end": 797.28,
      "text": "那些所谓的你对她好的东西"
