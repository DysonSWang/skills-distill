    {
      "start": 202.28,
      "end": 203.28,
      "text": "我保持了"
    },
    {
      "start": 203.28,
      "end": 204.28,
      "text": "我一直对他很好"
    },
    {
      "start": 204.28,
      "end": 205.28,
      "text": "每天给他一块钱"
    },
    {
      "start": 205.28,
      "end": 207.28,
      "text": "他会开始找我要两块钱了"
