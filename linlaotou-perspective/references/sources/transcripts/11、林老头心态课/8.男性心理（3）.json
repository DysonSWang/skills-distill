      "start": 739.28,
      "end": 740.28,
      "text": "不能说"
    },
    {
      "start": 740.28,
      "end": 743.28,
      "text": "可能说是他错了"
    },
    {
      "start": 743.28,
      "end": 744.28,
      "text": "可能是你错了"
