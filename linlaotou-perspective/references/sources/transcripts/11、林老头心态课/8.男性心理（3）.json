    {
      "start": 194.28,
      "end": 196.28,
      "text": "我保证了这个好的习惯"
    },
    {
      "start": 196.28,
      "end": 198.28,
      "text": "我每天还是给了他一块钱"
    },
    {
      "start": 198.28,
      "end": 200.28,
      "text": "我坚持这样做"
    },
    {
      "start": 200.28,
      "end": 202.28,
      "text": "过了两三个月"
