    {
      "start": 215.28,
      "end": 217.28,
      "text": "他会不满足于此"
    },
    {
      "start": 217.28,
      "end": 219.28,
      "text": "他会想要更好的东西"
    },
    {
      "start": 219.28,
      "end": 222.28,
      "text": "要么就是买不到更好的东西"
