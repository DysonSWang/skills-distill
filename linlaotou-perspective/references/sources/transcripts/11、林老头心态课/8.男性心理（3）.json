    },
    {
      "start": 731.28,
      "end": 733.28,
      "text": "所以说这个是什么"
    },
    {
      "start": 733.28,
      "end": 734.28,
      "text": "两个人的角度不同"
    },
    {
      "start": 734.28,
      "end": 736.28,
      "text": "两个人的观念不同"
    },
    {
      "start": 736.28,
      "end": 737.28,
      "text": "感受是不同的"
    },
    {
      "start": 737.28,
      "end": 739.28,
      "text": "你不能说谁做错了"
