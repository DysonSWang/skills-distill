    {
      "start": 497.62,
      "end": 498.52,
      "text": "但是呢"
    },
    {
      "start": 498.52,
      "end": 500.28000000000003,
      "text": "你不领这个情"
    },
    {
      "start": 500.28000000000003,
      "end": 502.86,
      "text": "那么我会收回我的好感"
    },
    {
      "start": 502.86,
      "end": 505.6,
      "text": "甚至还会对你很冷漠一点"
    },
    {
      "start": 505.6,
      "end": 506.32,
