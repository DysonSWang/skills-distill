    {
      "start": 616.0,
      "end": 618.0,
      "text": "这些都不重要"
    },
    {
      "start": 618.0,
      "end": 620.0,
      "text": "重要的是先拿到结果"
    },
    {
      "start": 620.0,
      "end": 622.0,
      "text": "很多人跟我说什么的"
