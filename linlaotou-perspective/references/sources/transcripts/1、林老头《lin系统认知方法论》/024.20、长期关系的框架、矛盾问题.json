    {
      "start": 588.1400000000001,
      "end": 588.44,
      "text": "OK"
    },
    {
      "start": 588.44,
      "end": 589.48,
      "text": "你的价值什么有问题"
    },
    {
      "start": 589.48,
      "end": 590.26,
      "text": "框架有问题"
    },
    {
      "start": 590.26,
      "end": 590.58,
      "text": "对吧"
    },
    {
      "start": 590.58,
      "end": 592.76,
      "text": "因为你们的关系是很重要的"
    },
    {
      "start": 592.76,
      "end": 593.72,
      "text": "包括一些细节"
    },
    {
      "start": 593.72,
      "end": 594.08,
      "text": "这些东西"
    },
    {
      "start": 594.08,
      "end": 597.0400000000001,
      "text": "都是水里面的一个历史"
    },
    {
      "start": 597.0400000000001,
      "end": 598.34,
      "text": "一定要确认这样做"
    },
    {
      "start": 598.34,
      "end": 599.98,
      "text": "背景框架解决问题"
    },
    {
      "start": 599.98,
      "end": 602.14,
      "text": "这个东西是处于长期关系"
    },
    {
      "start": 602.14,
      "end": 603.6,
      "text": "作为那些课的一个弥补"
