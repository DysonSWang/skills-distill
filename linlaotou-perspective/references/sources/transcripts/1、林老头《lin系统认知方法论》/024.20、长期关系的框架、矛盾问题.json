      "start": 577.22,
      "end": 579.44,
      "text": "你只需要告诉他他该做什么就可以了"
    },
    {
      "start": 579.44,
      "end": 580.34,
      "text": "他该做什么"
    },
    {
      "start": 580.34,
      "end": 581.1800000000001,
      "text": "怎么配合你"
    },
    {
      "start": 583.6800000000001,
      "end": 584.0,
      "text": "OK"
    },
    {
      "start": 584.0,
      "end": 585.44,
      "text": "如果我们说到不说回来"
    },
    {
      "start": 585.44,
