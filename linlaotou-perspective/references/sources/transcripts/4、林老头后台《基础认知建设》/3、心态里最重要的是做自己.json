    },
    {
      "start": 241.26,
      "end": 244.1,
      "text": "我还是保留着一丝余地"
    },
    {
      "start": 244.1,
      "end": 245.78,
      "text": "就是你可能会离开我"
    },
    {
      "start": 245.78,
      "end": 247.94,
      "text": "可能我们俩的关系"
    },
    {
      "start": 247.94,
      "end": 249.72,
