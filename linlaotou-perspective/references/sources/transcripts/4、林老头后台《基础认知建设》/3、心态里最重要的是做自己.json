      "start": 265.98,
      "end": 267.2,
      "text": "就好像你"
    },
    {
      "start": 267.22,
      "end": 268.06,
      "text": "你约一个旅行出来"
    },
    {
      "start": 268.06,
      "end": 269.22,
      "text": "其实你对这是约会"
    },
    {
      "start": 269.22,
      "end": 269.90000000000003,
      "text": "OK"
    },
    {
      "start": 269.90000000000003,
      "end": 270.34000000000003,
      "text": "他不来"
    },
    {
      "start": 270.34000000000003,
      "end": 271.32000000000005,
      "text": "他割了你这件事情"
    },
    {
      "start": 271.32000000000005,
      "end": 272.34000000000003,
      "text": "你早有心理准备"
    },
    {
      "start": 272.34000000000003,
      "end": 273.90000000000003,
      "text": "那么你真的被割了"
    },
    {
      "start": 273.90000000000003,
