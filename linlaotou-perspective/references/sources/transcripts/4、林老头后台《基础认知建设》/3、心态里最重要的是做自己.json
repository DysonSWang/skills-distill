    {
      "start": 166.32,
      "end": 168.1,
      "text": "那这个东西是可行的"
    },
    {
      "start": 168.1,
      "end": 169.9,
      "text": "因为你是以理为核心的"
    },
    {
      "start": 169.9,
      "end": 171.66,
      "text": "你自己以自己为核心"
    },
    {
      "start": 171.66,
      "end": 173.4,
      "text": "那么你自己永远不会背叛你"
    },
    {
      "start": 173.4,
      "end": 174.84,
      "text": "你自己永远不会欺骗自己"
    },
    {
      "start": 174.84,
      "end": 175.78,
      "text": "知道吧"
    },
    {
      "start": 175.78,
      "end": 177.2,
      "text": "但是别人会不相信你"
    },
    {
      "start": 177.22,
      "end": 177.62,
      "text": "别人不同"
    },
    {
      "start": 177.62,
      "end": 178.8,
      "text": "别人可能会背叛你"
    },
    {
      "start": 178.8,
      "end": 180.3,
      "text": "别人可能会欺骗你"
    },
    {
      "start": 180.3,
      "end": 180.58,
