      "text": "假设你真的被割了"
    },
    {
      "start": 275.62,
      "end": 276.70000000000005,
      "text": "这个对你来说"
    },
    {
      "start": 276.70000000000005,
      "end": 277.98,
      "text": "不会造成任何影响"
    },
    {
      "start": 277.98,
      "end": 279.82000000000005,
      "text": "就是我们中国有句老话叫"
    },
    {
      "start": 279.82000000000005,
      "end": 281.52000000000004,
      "text": "永远把事情往坏的地方想"
    },
    {
      "start": 281.52000000000004,
      "end": 284.20000000000005,
      "text": "就是关于个人预期的"
    },
    {
      "start": 284.20000000000005,
      "end": 286.46000000000004,
      "text": "就是尽可能的降低自己的预期"
