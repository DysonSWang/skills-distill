    },
    {
      "start": 12.6,
      "end": 16.12,
      "text": "对对对"
    },
    {
      "start": 16.12,
      "end": 17.400000000000002,
      "text": "现在呢"
    },
    {
      "start": 17.400000000000002,
      "end": 19.48,
      "text": "他是发明这个的人"
    },
    {
      "start": 19.48,
      "end": 20.72,
      "text": "他是有这个专利的人"
    },
    {
      "start": 20.72,
      "end": 22.44,
      "text": "他发明了一个不知道什么样的东西"
    },
    {
      "start": 22.44,
      "end": 23.68,
      "text": "我也不知道这是什么"
    },
    {
      "start": 23.68,
      "end": 25.560000000000002,
      "text": "也许这是一个核弹头"
    },
    {
      "start": 25.560000000000002,
      "end": 28.28,
      "text": "也许这他妈的是一个风筝"
    },
    {
      "start": 28.68,
      "end": 29.6,
      "text": "也许是一个什么"
    },
    {
      "start": 29.6,
      "end": 31.240000000000002,
