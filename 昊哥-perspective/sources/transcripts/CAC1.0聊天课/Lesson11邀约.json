{
  "video": "CAC1.0聊天课/Lesson11邀约.mp4",
  "language": "zh",
  "duration": 200.5275625,
  "segments": [
    {
      "start": 0.0,
      "end": 6.0,
      "text": "-字幕-"
    },
    {
      "start": 6.0,
      "end": 6.88,
      "text": "Hello 大家好"
    },
    {
      "start": 6.88,
      "end": 8.48,
      "text": "欢迎来到CAC聊天法"
    },
    {
      "start": 8.48,
      "end": 9.4,
      "text": "我是浩哥"
    },
    {
      "start": 9.4,
      "end": 12.120000000000001,
      "text": "那么今天我们最后一节课"
    },
    {
      "start": 12.120000000000001,
      "end": 14.32,
      "text": "我要告诉大家这样一个观点"
    },
    {
      "start": 14.32,
      "end": 16.52,
      "text": "那就是通过手机聊天"
    },
    {
      "start": 16.52,
      "end": 18.64,
      "text": "确实能把女生对你的态度"
    },
    {
      "start": 18.64,
      "end": 20.92,
      "text": "抬到40以上甚至60"
    },
    {
      "start": 20.92,
      "end": 22.64,
      "text": "但这种方式需要你"
    },
    {
      "start": 22.64,
      "end": 26.080000000000002,
      "text": "不断地和女生聊天和互动来维持"
    },
    {
      "start": 26.080000000000002,
      "end": 28.68,
      "text": "并且对方随时有可能"
    },
    {
      "start": 28.72,
      "end": 30.4,
      "text": "跟其他男生接触"
    },
    {
      "start": 30.4,
      "end": 31.36,
      "text": "所以说"
    },
    {
      "start": 31.36,
      "end": 32.6,
      "text": "只有通过见面"
    },
    {
      "start": 32.6,
      "end": 34.519999999999996,
      "text": "约会面对面的相处"
    },
    {
      "start": 34.519999999999996,
      "end": 37.08,
      "text": "才能真正锁住女生对你的好感"
    },
    {
      "start": 37.08,
      "end": 38.519999999999996,
      "text": "那么所有约会的技巧"
    },
    {
      "start": 38.519999999999996,
      "end": 40.2,
      "text": "比如说挑选地点"
    },
    {
      "start": 40.2,
      "end": 40.88,
      "text": "转场"
    },
    {
      "start": 40.88,
      "end": 42.0,
      "text": "服从心测试"
    },
    {
      "start": 42.0,
      "end": 42.92,
      "text": "肢体升级"
    },
    {
      "start": 42.92,
      "end": 45.44,
      "text": "还有你想知道的所有其他内容"
    },
    {
      "start": 45.44,
      "end": 47.84,
      "text": "我会在未来放在约会课里"
    },
    {
      "start": 47.84,
      "end": 49.2,
      "text": "分享给大家"
    },
    {
      "start": 49.2,
      "end": 50.28,
      "text": "而这节课"
    },
    {
      "start": 50.28,
      "end": 51.760000000000005,
      "text": "我会教给大家一种"
    },
    {
      "start": 51.760000000000005,
      "end": 54.08,
      "text": "成功率最高的邀约技巧"
    },
    {
      "start": 54.08,
      "end": 56.879999999999995,
      "text": "首先就跟前面的所有技巧一样"
    },
    {
      "start": 56.92,
      "end": 60.36,
      "text": "邀约也需要在女生态度达到一定的阶段"
    },
    {
      "start": 60.36,
      "end": 61.6,
      "text": "才能进行"
    },
    {
      "start": 61.6,
      "end": 62.92,
      "text": "大家可能还记得"
    },
    {
      "start": 62.92,
      "end": 64.4,
      "text": "最开始我跟大家说过"
    },
    {
      "start": 64.4,
      "end": 66.24000000000001,
      "text": "女生愿意出来见你"
    },
    {
      "start": 66.24000000000001,
      "end": 70.24000000000001,
      "text": "最低最低只需要她的态度达到20就可以"
    },
    {
      "start": 70.24000000000001,
      "end": 72.32000000000001,
      "text": "但是这样的前提条件是"
    },
    {
      "start": 72.32000000000001,
      "end": 73.92,
      "text": "这个女生特别闲"
    },
    {
      "start": 73.92,
      "end": 75.12,
      "text": "她很无聊"
    },
    {
      "start": 75.12,
      "end": 77.96000000000001,
      "text": "所以她想找个人见面打发时间"
    },
    {
      "start": 77.96000000000001,
      "end": 81.2,
      "text": "如果你想约的女生平时很忙"
    },
    {
      "start": 81.2,
      "end": 82.28,
      "text": "很充实"
    },
    {
      "start": 82.28,
      "end": 85.84,
      "text": "你就要尽量的把她的态度推到40"
    },
    {
      "start": 85.88000000000001,
      "end": 88.92,
      "text": "看到兴趣指标以后再进行邀约"
    },
    {
      "start": 88.92,
      "end": 92.60000000000001,
      "text": "这样才能最大化保证邀约的成功率"
    },
    {
      "start": 92.60000000000001,
      "end": 94.12,
      "text": "回到实战中"
    },
    {
      "start": 94.12,
      "end": 97.0,
      "text": "什么样的时机最适合进行邀约呢"
    },
    {
      "start": 97.0,
      "end": 99.16,
      "text": "就是当你捕捉到对方在"
    },
    {
      "start": 99.16,
      "end": 102.16,
      "text": "连续释放兴趣指标的时候"
    },
    {
      "start": 102.16,
      "end": 104.12,
      "text": "比方说一个女生会主动问你"
    },
    {
      "start": 104.12,
      "end": 105.4,
      "text": "会不会做饭"
    },
    {
      "start": 105.4,
      "end": 106.64,
      "text": "你告诉她说不会"
    },
    {
      "start": 106.64,
      "end": 109.12,
      "text": "可是她依然过来认可你说"
    },
    {
      "start": 109.12,
      "end": 109.52000000000001,
      "text": "对啊"
    },
    {
      "start": 109.52000000000001,
      "end": 110.72,
      "text": "毕竟你工作这么忙"
    },
    {
      "start": 110.72,
      "end": 112.0,
      "text": "不会应该的"
    },
    {
      "start": 112.0,
      "end": 113.76,
      "text": "这个时候你就意识到"
    },
    {
      "start": 113.80000000000001,
      "end": 115.16000000000001,
      "text": "首先她先提问"
    },
    {
      "start": 115.16000000000001,
      "end": 116.2,
      "text": "再认可你"
    },
    {
      "start": 116.2,
      "end": 118.24000000000001,
      "text": "就证明了她对你的态度"
    },
    {
      "start": 118.24000000000001,
      "end": 120.36,
      "text": "明确的超过了40"
    },
    {
      "start": 120.36,
      "end": 121.88000000000001,
      "text": "这个时候你再约她"
    },
    {
      "start": 121.88000000000001,
      "end": 123.60000000000001,
      "text": "极大概率她会答应"
    },
    {
      "start": 123.60000000000001,
      "end": 125.88000000000001,
      "text": "如果女生始终没有给我们"
    },
    {
      "start": 125.88000000000001,
      "end": 128.68,
      "text": "连续兴趣指标该怎么办呢"
    },
    {
      "start": 128.68,
      "end": 130.72,
      "text": "这个时候我们就可以利用"
    },
    {
      "start": 130.72,
      "end": 132.4,
      "text": "模糊邀约的技巧"
    },
    {
      "start": 132.4,
      "end": 134.8,
      "text": "先不跟女生敲定时间"
    },
    {
      "start": 134.8,
      "end": 137.16,
      "text": "只大概说一下你们要去做什么"
    },
    {
      "start": 137.16,
      "end": 138.32,
      "text": "比如说"
    },
    {
      "start": 138.32,
      "end": 139.56,
      "text": "回头有时间"
    },
    {
      "start": 139.56,
      "end": 141.36,
      "text": "我约你一块喝咖啡"
    },
    {
      "start": 141.36,
      "end": 142.8,
      "text": "或者下次有机会"
    },
    {
      "start": 142.84,
      "end": 144.68,
      "text": "我们一块去看球赛"
    },
    {
      "start": 144.68,
      "end": 146.88000000000002,
      "text": "这种邀约的好处在于"
    },
    {
      "start": 146.88000000000002,
      "end": 149.8,
      "text": "女生的心理负担会非常小"
    },
    {
      "start": 149.8,
      "end": 151.08,
      "text": "因为她有可能觉得"
    },
    {
      "start": 151.08,
      "end": 153.8,
      "text": "你的邀约只是出于礼貌和客气"
    },
    {
      "start": 153.8,
      "end": 156.24,
      "text": "她非常容易就口头答应"
    },
    {
      "start": 156.24,
      "end": 158.12,
      "text": "所以当我们拿不准的时候"
    },
    {
      "start": 158.12,
      "end": 160.16000000000003,
      "text": "就可以先用模糊邀约"
    },
    {
      "start": 160.16000000000003,
      "end": 161.64000000000001,
      "text": "试探对方的态度"
    },
    {
      "start": 161.64000000000001,
      "end": 163.8,
      "text": "如果模糊邀约她都拒绝了"
    },
    {
      "start": 163.8,
      "end": 165.36,
      "text": "就说明你们的关系"
    },
    {
      "start": 165.36,
      "end": 168.12,
      "text": "还需要慢慢的继续拉升"
    },
    {
      "start": 168.12,
      "end": 170.24,
      "text": "而如果她答应了模糊邀约"
    },
    {
      "start": 170.24,
      "end": 172.4,
      "text": "那随后你就可以找机会"
    },
    {
      "start": 172.4,
      "end": 173.76000000000002,
      "text": "进行具体邀约"
    },
    {
      "start": 173.76000000000002,
      "end": 176.0,
      "text": "去敲定见面的细节"
    },
    {
      "start": 176.0,
      "end": 176.52,
      "text": "OK"
    },
    {
      "start": 176.52,
      "end": 177.8,
      "text": "那到这里为止"
    },
    {
      "start": 177.8,
      "end": 179.72,
      "text": "我们这套CAC聊天法"
    },
    {
      "start": 179.72,
      "end": 182.12,
      "text": "就全部讲解完了"
    },
    {
      "start": 182.12,
      "end": 184.76000000000002,
      "text": "如果你从第一节课坚持看到最后"
    },
    {
      "start": 184.76000000000002,
      "end": 185.72,
      "text": "那恭喜你"
    },
    {
      "start": 185.72,
      "end": 187.84,
      "text": "你已经掌握了通过聊天"
    },
    {
      "start": 187.84,
      "end": 190.28,
      "text": "最大化吸引女生的技巧"
    },
    {
      "start": 190.28,
      "end": 192.08,
      "text": "如果大家有什么疑问"
    },
    {
      "start": 192.08,
      "end": 193.60000000000002,
      "text": "欢迎找我私聊"
    },
    {
      "start": 193.60000000000002,
      "end": 196.28,
      "text": "最后感谢大家对浩哥的支持"
    },
    {
      "start": 196.28,
      "end": 199.0,
      "text": "以及对CAC聊天法的关注"
    },
    {
      "start": 199.0,
      "end": 200.48,
      "text": "我们下次再见"
    }
  ]
}