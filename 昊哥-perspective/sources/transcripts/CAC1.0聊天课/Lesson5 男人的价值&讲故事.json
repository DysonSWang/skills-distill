{
  "video": "CAC1.0聊天课/Lesson5 男人的价值&讲故事.mp4",
  "language": "zh",
  "duration": 460.2659375,
  "segments": [
    {
      "start": 0.0,
      "end": 6.08,
      "text": "【CAC聊天法】"
    },
    {
      "start": 6.08,
      "end": 6.76,
      "text": "Hello 大家好"
    },
    {
      "start": 6.76,
      "end": 7.5200000000000005,
      "text": "我是浩哥"
    },
    {
      "start": 7.5200000000000005,
      "end": 9.84,
      "text": "欢迎来到CAC聊天法"
    },
    {
      "start": 9.84,
      "end": 10.88,
      "text": "上一段咱们说过"
    },
    {
      "start": 10.88,
      "end": 14.24,
      "text": "想把女生的态度稳固到20之上"
    },
    {
      "start": 14.24,
      "end": 16.84,
      "text": "有三种操作是非常重要的"
    },
    {
      "start": 16.84,
      "end": 19.8,
      "text": "展示幽默、冷度数和讲故事"
    },
    {
      "start": 19.8,
      "end": 21.6,
      "text": "那么今天我就来教大家"
    },
    {
      "start": 21.6,
      "end": 23.72,
      "text": "如何通过讲故事的技巧"
    },
    {
      "start": 23.72,
      "end": 26.400000000000002,
      "text": "去展示价值吸引女生"
    },
    {
      "start": 26.400000000000002,
      "end": 27.32,
      "text": "说到价值"
    },
    {
      "start": 27.32,
      "end": 29.240000000000002,
      "text": "很多人都觉得男人的价值"
    },
    {
      "start": 29.240000000000002,
      "end": 30.560000000000002,
      "text": "无非就是两种"
    },
    {
      "start": 30.560000000000002,
      "end": 31.64,
      "text": "要么就是有钱"
    },
    {
      "start": 31.64,
      "end": 33.160000000000004,
      "text": "要么就是长得帅"
    },
    {
      "start": 33.160000000000004,
      "end": 35.84,
      "text": "但其实这个说法是比较狭隘的"
    },
    {
      "start": 35.84,
      "end": 38.440000000000005,
      "text": "价值的概念远远不止于此"
    },
    {
      "start": 38.440000000000005,
      "end": 41.440000000000005,
      "text": "心理学界对于女性子偶的判断标准"
    },
    {
      "start": 41.440000000000005,
      "end": 42.96,
      "text": "分成了两大类"
    },
    {
      "start": 42.96,
      "end": 44.52,
      "text": "也就是两种价值"
    },
    {
      "start": 44.52,
      "end": 46.32000000000001,
      "text": "主价值和副价值"
    },
    {
      "start": 46.32000000000001,
      "end": 48.88,
      "text": "也叫做软价值和硬价值"
    },
    {
      "start": 48.88,
      "end": 50.040000000000006,
      "text": "打个比方"
    },
    {
      "start": 50.040000000000006,
      "end": 51.8,
      "text": "如果把追生女生"
    },
    {
      "start": 51.8,
      "end": 53.96,
      "text": "比喻成一个网络游戏的话"
    },
    {
      "start": 53.96,
      "end": 57.400000000000006,
      "text": "主价值就是我们玩的角色的等级"
    },
    {
      "start": 57.44,
      "end": 60.16,
      "text": "包括攻击力、敏捷、防御力"
    },
    {
      "start": 60.16,
      "end": 61.64,
      "text": "这些个属性"
    },
    {
      "start": 61.64,
      "end": 62.96,
      "text": "它对应到生活里"
    },
    {
      "start": 62.96,
      "end": 66.64,
      "text": "就是我们的性格、自信心、幽默感"
    },
    {
      "start": 66.64,
      "end": 70.36,
      "text": "见识、逻辑思维、气场等等"
    },
    {
      "start": 70.36,
      "end": 73.32,
      "text": "而副价值就是我们身上的装备"
    },
    {
      "start": 73.32,
      "end": 74.44,
      "text": "对应到生活里"
    },
    {
      "start": 74.44,
      "end": 75.84,
      "text": "就是你的外表"
    },
    {
      "start": 75.84,
      "end": 78.08,
      "text": "你的身高、长相"
    },
    {
      "start": 78.08,
      "end": 80.16,
      "text": "还有你的车、你的钱"
    },
    {
      "start": 80.16,
      "end": 82.6,
      "text": "还有你的工作、学历等等"
    },
    {
      "start": 82.6,
      "end": 84.16,
      "text": "那么你追女生的过程"
    },
    {
      "start": 84.16,
      "end": 86.16,
      "text": "其实就像是你去打boss"
    },
    {
      "start": 86.16,
      "end": 88.11999999999999,
      "text": "如果你花钱充值了"
    },
    {
      "start": 88.11999999999999,
      "end": 89.67999999999999,
      "text": "当然装备越好"
    },
    {
      "start": 89.67999999999999,
      "end": 91.28,
      "text": "打的确实越容易"
    },
    {
      "start": 91.28,
      "end": 93.32,
      "text": "但是如果你没有钱"
    },
    {
      "start": 93.32,
      "end": 94.75999999999999,
      "text": "慢慢去练习"
    },
    {
      "start": 94.75999999999999,
      "end": 97.67999999999999,
      "text": "同样你也是有机会可以打的"
    },
    {
      "start": 97.67999999999999,
      "end": 98.36,
      "text": "当然了"
    },
    {
      "start": 98.36,
      "end": 99.75999999999999,
      "text": "最好的状态一定是你"
    },
    {
      "start": 99.75999999999999,
      "end": 102.03999999999999,
      "text": "既有钱又有软价值"
    },
    {
      "start": 102.03999999999999,
      "end": 105.96,
      "text": "所以这也是我们每个人的提升目标"
    },
    {
      "start": 105.96,
      "end": 109.32,
      "text": "说这些是想纠正大家的一个思维误区"
    },
    {
      "start": 109.32,
      "end": 112.19999999999999,
      "text": "觉得只有有钱才能追到女生"
    },
    {
      "start": 112.19999999999999,
      "end": 113.32,
      "text": "或者说有钱了"
    },
    {
      "start": 113.32,
      "end": 115.08,
      "text": "泡妞酒无敌了"
    },
    {
      "start": 115.12,
      "end": 117.24,
      "text": "实际上女人对于钱"
    },
    {
      "start": 117.24,
      "end": 118.96,
      "text": "只会设一个门槛"
    },
    {
      "start": 118.96,
      "end": 120.28,
      "text": "或者叫最低门槛"
    },
    {
      "start": 120.28,
      "end": 122.44,
      "text": "我们也叫做fuckable wine"
    },
    {
      "start": 122.44,
      "end": 123.24,
      "text": "也就是说"
    },
    {
      "start": 123.24,
      "end": 124.16,
      "text": "过了这个槛"
    },
    {
      "start": 124.16,
      "end": 125.8,
      "text": "她就可以接受你"
    },
    {
      "start": 125.8,
      "end": 128.36,
      "text": "如果是谈恋爱、谈感情"
    },
    {
      "start": 128.36,
      "end": 129.88,
      "text": "而不是去相亲"
    },
    {
      "start": 129.88,
      "end": 132.24,
      "text": "直接物质条件去匹配的话"
    },
    {
      "start": 132.24,
      "end": 135.72,
      "text": "其实钱的作用真的没有那么大"
    },
    {
      "start": 135.72,
      "end": 136.8,
      "text": "而真正那种"
    },
    {
      "start": 136.8,
      "end": 139.28,
      "text": "只看现在你的钱的拜金女"
    },
    {
      "start": 139.28,
      "end": 141.6,
      "text": "你肯定也不会对他们感兴趣"
    },
    {
      "start": 141.6,
      "end": 144.48,
      "text": "前面这些铺垫是为了告诉大家"
    },
    {
      "start": 144.51999999999998,
      "end": 145.92,
      "text": "想要吸引女生"
    },
    {
      "start": 145.92,
      "end": 148.88,
      "text": "就要充分的去展示你的价值"
    },
    {
      "start": 148.88,
      "end": 151.23999999999998,
      "text": "但是如果你直接去秀的话"
    },
    {
      "start": 151.23999999999998,
      "end": 152.12,
      "text": "比如你跟她说"
    },
    {
      "start": 152.12,
      "end": 153.95999999999998,
      "text": "我开的是保时捷"
    },
    {
      "start": 153.95999999999998,
      "end": 156.67999999999998,
      "text": "那样就会让人觉得你是在显摆"
    },
    {
      "start": 156.67999999999998,
      "end": 159.07999999999998,
      "text": "她可能会觉得不舒服或者挺尴尬"
    },
    {
      "start": 159.07999999999998,
      "end": 161.88,
      "text": "而且如果对方条件也挺不错的话"
    },
    {
      "start": 161.88,
      "end": 165.16,
      "text": "她还会觉得你这个行为有点幼稚"
    },
    {
      "start": 165.16,
      "end": 166.64,
      "text": "这是说硬价值"
    },
    {
      "start": 166.64,
      "end": 168.56,
      "text": "那么展示软价值的时候"
    },
    {
      "start": 168.56,
      "end": 170.23999999999998,
      "text": "如果你跟一个女生说"
    },
    {
      "start": 170.23999999999998,
      "end": 171.64,
      "text": "我人缘很好"
    },
    {
      "start": 171.64,
      "end": 172.95999999999998,
      "text": "那女生会觉得"
    },
    {
      "start": 173.0,
      "end": 175.16,
      "text": "你突然说这么一句话很奇怪"
    },
    {
      "start": 175.16,
      "end": 178.16,
      "text": "好像是在刻意的去抬高你自己"
    },
    {
      "start": 178.16,
      "end": 180.76000000000002,
      "text": "反而她会去质疑你的情商"
    },
    {
      "start": 180.76000000000002,
      "end": 183.72,
      "text": "那么我们如何才能顺滑"
    },
    {
      "start": 183.72,
      "end": 185.8,
      "text": "不刻意的展示价值呢"
    },
    {
      "start": 185.8,
      "end": 188.88,
      "text": "这就要用到讲故事的技巧"
    },
    {
      "start": 188.88,
      "end": 189.96,
      "text": "讲故事是指"
    },
    {
      "start": 189.96,
      "end": 192.52,
      "text": "把你的价值和你的优点"
    },
    {
      "start": 192.52,
      "end": 194.72,
      "text": "包裹在一件事情里"
    },
    {
      "start": 194.72,
      "end": 197.36,
      "text": "通过跟女生讲述这件事"
    },
    {
      "start": 197.36,
      "end": 200.0,
      "text": "从而让她自己体会出你的价值"
    },
    {
      "start": 200.0,
      "end": 201.0,
      "text": "举个例子"
    },
    {
      "start": 201.0,
      "end": 202.44,
      "text": "比如你在北京"
    },
    {
      "start": 202.48,
      "end": 204.48,
      "text": "然后有一辆还不错的车"
    },
    {
      "start": 204.48,
      "end": 207.56,
      "text": "你就可以跟女生先聊到上下班的通勤"
    },
    {
      "start": 207.56,
      "end": 209.48,
      "text": "然后带出你的故事"
    },
    {
      "start": 209.48,
      "end": 211.0,
      "text": "比如你可以说"
    },
    {
      "start": 211.0,
      "end": 213.48,
      "text": "我最近都打车或者坐机前上班了"
    },
    {
      "start": 213.48,
      "end": 214.92,
      "text": "早上路太堵了"
    },
    {
      "start": 214.92,
      "end": 216.48,
      "text": "好多人都乱挤"
    },
    {
      "start": 216.48,
      "end": 219.56,
      "text": "上次我就让一辆电动车给蹭了"
    },
    {
      "start": 219.56,
      "end": 222.32,
      "text": "补期补掉一年打车钱"
    },
    {
      "start": 222.32,
      "end": 223.8,
      "text": "这样对方一盘算"
    },
    {
      "start": 223.8,
      "end": 226.36,
      "text": "一年打车钱起码得有两三万"
    },
    {
      "start": 226.36,
      "end": 227.72,
      "text": "补个期就这么贵"
    },
    {
      "start": 227.72,
      "end": 230.68,
      "text": "说明你开的肯定是一辆还不错的车"
    },
    {
      "start": 230.72,
      "end": 232.72,
      "text": "对方就会了解到你的硬价值"
    },
    {
      "start": 232.72,
      "end": 233.76000000000002,
      "text": "你的经济实力"
    },
    {
      "start": 234.4,
      "end": 235.48000000000002,
      "text": "再举个例子"
    },
    {
      "start": 235.48000000000002,
      "end": 237.48000000000002,
      "text": "说说软价值该怎么展示"
    },
    {
      "start": 237.48000000000002,
      "end": 239.04000000000002,
      "text": "比方说对方问你"
    },
    {
      "start": 239.04000000000002,
      "end": 240.76000000000002,
      "text": "你喜欢什么样的女生"
    },
    {
      "start": 240.76000000000002,
      "end": 243.4,
      "text": "相比于直接给她你的答案"
    },
    {
      "start": 243.4,
      "end": 245.12,
      "text": "你不如用讲故事的技巧"
    },
    {
      "start": 245.12,
      "end": 247.28,
      "text": "去传递你的价值"
    },
    {
      "start": 247.28,
      "end": 248.20000000000002,
      "text": "你可以说"
    },
    {
      "start": 248.20000000000002,
      "end": 250.88,
      "text": "以前肯定就是喜欢长得漂亮的"
    },
    {
      "start": 250.88,
      "end": 252.84,
      "text": "但是后来大学谈了一个"
    },
    {
      "start": 252.84,
      "end": 253.92000000000002,
      "text": "就虽然漂亮"
    },
    {
      "start": 253.92000000000002,
      "end": 255.44,
      "text": "但是真的了不来"
    },
    {
      "start": 255.44,
      "end": 256.96000000000004,
      "text": "就比方说我想去图书馆"
    },
    {
      "start": 256.96000000000004,
      "end": 258.44,
      "text": "或者我想去打球锻炼"
    },
    {
      "start": 258.44,
      "end": 259.56,
      "text": "她都没兴趣"
    },
    {
      "start": 259.6,
      "end": 262.0,
      "text": "天天就知道拉着我打游戏"
    },
    {
      "start": 262.0,
      "end": 263.36,
      "text": "所以后来我还是觉得"
    },
    {
      "start": 263.36,
      "end": 264.72,
      "text": "还是得找"
    },
    {
      "start": 264.72,
      "end": 266.28000000000003,
      "text": "生活态度比较积极"
    },
    {
      "start": 266.28000000000003,
      "end": 267.2,
      "text": "阳光的那种"
    },
    {
      "start": 268.16,
      "end": 269.56,
      "text": "你看通过这个故事"
    },
    {
      "start": 269.56,
      "end": 271.36,
      "text": "你传递出了三个价值"
    },
    {
      "start": 271.36,
      "end": 272.08,
      "text": "第一"
    },
    {
      "start": 272.08,
      "end": 273.96,
      "text": "你谈过很漂亮的女生"
    },
    {
      "start": 273.96,
      "end": 276.16,
      "text": "这个就证明了你有足够的货"
    },
    {
      "start": 276.16,
      "end": 278.08,
      "text": "去吸引漂亮女生"
    },
    {
      "start": 278.08,
      "end": 278.64,
      "text": "第二"
    },
    {
      "start": 278.64,
      "end": 281.48,
      "text": "你的生活是非常健康积极的"
    },
    {
      "start": 281.48,
      "end": 282.36,
      "text": "业余的时间"
    },
    {
      "start": 282.36,
      "end": 284.48,
      "text": "你会去健身阅读"
    },
    {
      "start": 284.48,
      "end": 285.68,
      "text": "提升自己"
    },
    {
      "start": 285.68,
      "end": 288.52,
      "text": "第三就是你面对女人的态度"
    },
    {
      "start": 288.52,
      "end": 291.28,
      "text": "你是一种筛选挑选的心态"
    },
    {
      "start": 291.28,
      "end": 292.4,
      "text": "这个就暗示出"
    },
    {
      "start": 292.4,
      "end": 295.32,
      "text": "你是一个有选择权的男人"
    },
    {
      "start": 295.32,
      "end": 296.88,
      "text": "你会主动排除掉"
    },
    {
      "start": 296.88,
      "end": 298.52,
      "text": "不符合你要求的女生"
    },
    {
      "start": 298.52,
      "end": 300.59999999999997,
      "text": "说明你应该很优秀"
    },
    {
      "start": 300.59999999999997,
      "end": 303.15999999999997,
      "text": "身边有很多的这种女生资源"
    },
    {
      "start": 303.15999999999997,
      "end": 305.03999999999996,
      "text": "所以这里总结一下"
    },
    {
      "start": 305.03999999999996,
      "end": 306.79999999999995,
      "text": "讲故事核心在于"
    },
    {
      "start": 306.79999999999995,
      "end": 308.32,
      "text": "在聊天的过程中"
    },
    {
      "start": 308.32,
      "end": 310.32,
      "text": "很自然的去讲述"
    },
    {
      "start": 310.32,
      "end": 313.79999999999995,
      "text": "能假现自己价值的经历和故事"
    },
    {
      "start": 313.79999999999995,
      "end": 315.03999999999996,
      "text": "那么和直接说"
    },
    {
      "start": 315.03999999999996,
      "end": 317.32,
      "text": "或者直接去炫耀相比起来"
    },
    {
      "start": 317.32,
      "end": 318.4,
      "text": "讲故事的好处"
    },
    {
      "start": 318.44000000000005,
      "end": 320.88000000000005,
      "text": "在于增添了一份神秘感"
    },
    {
      "start": 320.88000000000005,
      "end": 321.88000000000005,
      "text": "低调感"
    },
    {
      "start": 321.88000000000005,
      "end": 323.08000000000004,
      "text": "让女生告诉你"
    },
    {
      "start": 323.08000000000004,
      "end": 324.88000000000005,
      "text": "你好像不想告诉她你的价值"
    },
    {
      "start": 324.88000000000005,
      "end": 327.52000000000004,
      "text": "或者你是在有意隐藏价值"
    },
    {
      "start": 327.52000000000004,
      "end": 329.52000000000004,
      "text": "只不过你恰巧聊到这个话题"
    },
    {
      "start": 329.52000000000004,
      "end": 331.56000000000006,
      "text": "也就顺便说出来"
    },
    {
      "start": 331.56000000000006,
      "end": 332.6,
      "text": "咱们可以想想"
    },
    {
      "start": 332.6,
      "end": 334.96000000000004,
      "text": "什么人会去刻意低调"
    },
    {
      "start": 334.96000000000004,
      "end": 337.88000000000005,
      "text": "刻意隐藏自己的实力和身份"
    },
    {
      "start": 337.88000000000005,
      "end": 339.76000000000005,
      "text": "一定是真正有价值"
    },
    {
      "start": 339.76000000000005,
      "end": 341.96000000000004,
      "text": "而且足够自信的人"
    },
    {
      "start": 341.96000000000004,
      "end": 343.84000000000003,
      "text": "因为一般低价值的人"
    },
    {
      "start": 343.84000000000003,
      "end": 345.24,
      "text": "稍微有点什么物质条件"
    },
    {
      "start": 345.24,
      "end": 346.52000000000004,
      "text": "或者性格优势"
    },
    {
      "start": 346.56,
      "end": 349.15999999999997,
      "text": "他一定会拿到这个台面上来说"
    },
    {
      "start": 349.15999999999997,
      "end": 350.76,
      "text": "甚至有些人恨不得"
    },
    {
      "start": 350.76,
      "end": 353.12,
      "text": "想让全世界都知道自己有什么"
    },
    {
      "start": 353.12,
      "end": 354.64,
      "text": "或者刚买了什么"
    },
    {
      "start": 354.64,
      "end": 357.24,
      "text": "但实际上人越炫耀什么"
    },
    {
      "start": 357.24,
      "end": 359.79999999999995,
      "text": "越说明他在这方面还不够自信"
    },
    {
      "start": 359.79999999999995,
      "end": 361.52,
      "text": "那么我们讲故事的技巧"
    },
    {
      "start": 361.52,
      "end": 362.76,
      "text": "就是在教大家"
    },
    {
      "start": 362.76,
      "end": 365.64,
      "text": "避免这种不自信匮乏的表达"
    },
    {
      "start": 365.64,
      "end": 367.96,
      "text": "取而代之一种很自信"
    },
    {
      "start": 367.96,
      "end": 369.24,
      "text": "有神秘感"
    },
    {
      "start": 369.24,
      "end": 372.44,
      "text": "另外让听者非常舒适的表达"
    },
    {
      "start": 372.44,
      "end": 373.76,
      "text": "那么再举个例子"
    },
    {
      "start": 373.76,
      "end": 375.28,
      "text": "比如当你想告诉"
    },
    {
      "start": 375.32000000000005,
      "end": 376.68,
      "text": "对方你有健身的习惯"
    },
    {
      "start": 376.68,
      "end": 378.00000000000006,
      "text": "你很自律的时候"
    },
    {
      "start": 378.00000000000006,
      "end": 379.48,
      "text": "你可以跟他说"
    },
    {
      "start": 379.48,
      "end": 380.76000000000005,
      "text": "我今天下班特累"
    },
    {
      "start": 380.76000000000005,
      "end": 382.12,
      "text": "就想回家躺着"
    },
    {
      "start": 382.12,
      "end": 383.28000000000003,
      "text": "然后不过犹豫了一下"
    },
    {
      "start": 383.28000000000003,
      "end": 384.8,
      "text": "还是去蹲了个腿"
    },
    {
      "start": 384.8,
      "end": 386.96000000000004,
      "text": "练完感觉还挺爽的"
    },
    {
      "start": 386.96000000000004,
      "end": 387.76000000000005,
      "text": "这样说"
    },
    {
      "start": 387.76000000000005,
      "end": 390.28000000000003,
      "text": "对方不仅仅能感受到你的优点"
    },
    {
      "start": 390.28000000000003,
      "end": 393.84000000000003,
      "text": "而且接下来非常容易去话题延伸"
    },
    {
      "start": 393.84000000000003,
      "end": 395.08000000000004,
      "text": "你们可以聊健身"
    },
    {
      "start": 395.08000000000004,
      "end": 396.0,
      "text": "可以聊加班"
    },
    {
      "start": 396.0,
      "end": 397.56000000000006,
      "text": "可以聊住在哪"
    },
    {
      "start": 397.56000000000006,
      "end": 399.44000000000005,
      "text": "总之通过这一个故事"
    },
    {
      "start": 399.44000000000005,
      "end": 402.44000000000005,
      "text": "也很容易的就去引导出不同的话题"
    },
    {
      "start": 402.44000000000005,
      "end": 403.6,
      "text": "上面这三个例子"
    },
    {
      "start": 403.64000000000004,
      "end": 405.88,
      "text": "就是想让大家直观的了解到"
    },
    {
      "start": 405.88,
      "end": 408.88,
      "text": "究竟该怎么用讲故事的技巧"
    },
    {
      "start": 408.88,
      "end": 410.48,
      "text": "但是这三个例子"
    },
    {
      "start": 410.48,
      "end": 412.08000000000004,
      "text": "终究只是一个引子"
    },
    {
      "start": 412.08000000000004,
      "end": 414.36,
      "text": "还是需要你自己去挖掘"
    },
    {
      "start": 414.36,
      "end": 416.0,
      "text": "自己的优点和特质"
    },
    {
      "start": 416.0,
      "end": 418.96000000000004,
      "text": "自己有哪些可以挖掘价值"
    },
    {
      "start": 418.96000000000004,
      "end": 421.28000000000003,
      "text": "值得分享的经历和故事"
    },
    {
      "start": 421.28000000000003,
      "end": 423.28000000000003,
      "text": "并且好好的打磨一下"
    },
    {
      "start": 423.28000000000003,
      "end": 424.36,
      "text": "你自己的故事"
    },
    {
      "start": 424.36,
      "end": 428.12,
      "text": "还有描述故事的语言表达方式"
    },
    {
      "start": 428.12,
      "end": 430.0,
      "text": "因为只有靠这些故事"
    },
    {
      "start": 430.0,
      "end": 431.48,
      "text": "你才能让女生"
    },
    {
      "start": 431.52000000000004,
      "end": 433.8,
      "text": "立体的全面的了解你"
    },
    {
      "start": 433.8,
      "end": 435.76,
      "text": "和了解你的价值"
    },
    {
      "start": 435.76,
      "end": 438.40000000000003,
      "text": "在掌握了讲故事的技巧之后"
    },
    {
      "start": 438.40000000000003,
      "end": 440.6,
      "text": "如果你在对话里能做到"
    },
    {
      "start": 440.6,
      "end": 441.84000000000003,
      "text": "勇猛和冷独"
    },
    {
      "start": 441.84000000000003,
      "end": 443.72,
      "text": "基本上就可以把女生的态度"
    },
    {
      "start": 443.72,
      "end": 446.52000000000004,
      "text": "稳固在20到40之间了"
    },
    {
      "start": 446.52000000000004,
      "end": 447.48,
      "text": "后面的几节课"
    },
    {
      "start": 447.48,
      "end": 449.6,
      "text": "浩哥会教你突破40"
    },
    {
      "start": 449.6,
      "end": 451.08000000000004,
      "text": "这个兴趣门槛的技巧"
    },
    {
      "start": 451.08000000000004,
      "end": 453.44,
      "text": "然而在教大家如何突破之前"
    },
    {
      "start": 453.44,
      "end": 456.04,
      "text": "需要点出两个在这个阶段"
    },
    {
      "start": 456.04,
      "end": 457.84000000000003,
      "text": "大家最常犯的错误"
    },
    {
      "start": 457.84000000000003,
      "end": 458.84000000000003,
      "text": "那么具体内容"
    },
    {
      "start": 458.84000000000003,
      "end": 460.24,
      "text": "下节课带你学习"
    }
  ]
}