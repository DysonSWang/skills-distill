  "segments": [
    {
      "start": 0.0,
      "end": 4.0,
      "text": "OK"
    },
    {
      "start": 4.0,
      "end": 6.0,
      "text": "我们这个要做一个小的采访"
    },
    {
      "start": 6.0,
      "end": 8.0,
      "text": "这个采访里呢"
    },
    {
      "start": 8.0,
      "end": 10.0,
      "text": "他是"
    },
    {
      "start": 10.0,
      "end": 12.0,
      "text": "给我一个巴厘水吧"
    },
    {
      "start": 14.0,
      "end": 16.0,
      "text": "对对对"
    },
    {
      "start": 16.0,
      "end": 18.0,
      "text": "现在呢他是"
    },
    {
      "start": 18.0,
      "end": 20.0,
      "text": "他是发明这个的人"
    },
    {
      "start": 20.0,
      "end": 22.0,
      "text": "他是有这个专利的人 他发明了一个不知道什么样的东西"
    },
    {
      "start": 22.0,
      "end": 24.0,
      "text": "我也不知道这是什么"
    },
    {
      "start": 24.0,
      "end": 26.0,
