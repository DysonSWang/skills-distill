    {
      "start": 68.0,
      "end": 70.0,
      "text": "明明你是个红绿色"
    },
    {
      "start": 70.0,
      "end": 72.0,
      "text": "跨了"
    },
    {
      "start": 72.0,
      "end": 74.0,
      "text": "为什么"
    },
    {
      "start": 74.0,
      "end": 76.0,
      "text": "就这么说吧 为什么你是个红绿色盲"
    },
    {
      "start": 76.0,
      "end": 78.0,
      "text": "你要发明一个红的瓶子呢"
