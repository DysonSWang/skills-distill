    {
      "start": 296.0,
      "end": 298.0,
      "text": "为什么这个角指甲缝里的"
    },
    {
      "start": 298.0,
      "end": 300.0,
      "text": "你能够做成一支笔"
    },
    {
      "start": 300.0,
      "end": 302.0,
      "text": "为什么每一次我在跳伞的时候"
    },
    {
      "start": 302.0,
      "end": 304.0,
      "text": "他都能最后救我一命"
    },
    {
      "start": 304.0,
      "end": 306.0,
      "text": "就是"
