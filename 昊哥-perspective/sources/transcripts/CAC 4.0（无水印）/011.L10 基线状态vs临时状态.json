    {
      "start": 400.32000000000005,
      "end": 400.76000000000005,
      "text": "OK"
    },
    {
      "start": 402.24,
      "end": 402.88000000000005,
      "text": "那我们来"
    },
    {
      "start": 403.48,
      "end": 405.36,
      "text": "还好你们已经把上午"
    },
    {
      "start": 405.36,
      "end": 407.84000000000003,
      "text": "最重要的接受现实这个板块学到了"
