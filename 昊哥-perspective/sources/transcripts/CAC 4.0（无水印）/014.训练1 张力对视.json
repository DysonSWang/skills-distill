  "segments": [
    {
      "start": 0.0,
      "end": 4.12,
      "text": "OK,我们开始今天下午的训练"
    },
    {
      "start": 4.12,
      "end": 6.5200000000000005,
      "text": "今天下午我们要做的训练几乎会覆盖"
    },
    {
      "start": 6.88,
      "end": 7.96,
      "text": "你在社交环节中"
    },
    {
      "start": 7.96,
      "end": 9.48,
      "text": "不管是异性同性的社交"
    },
    {
      "start": 10.040000000000001,
      "end": 13.68,
      "text": "任何环节你要沟通所用到的情绪技能"
    },
    {
      "start": 13.68,
      "end": 14.8,
      "text": "我们都会涉及到"
    },
    {
      "start": 15.44,
      "end": 18.8,
      "text": "它会跟你生活里很多模式是特别类似的"
    },
    {
      "start": 18.8,
      "end": 19.2,
      "text": "好吧"
    },
    {
      "start": 19.400000000000002,
      "end": 20.92,
      "text": "我们来开始第一个训练"
    },
    {
      "start": 21.92,
      "end": 22.6,
      "text": "第一个训练"
    },
    {
      "start": 23.48,
      "end": 27.96,
      "text": "我想训练大家承受张力和释放张力的能力"
    },
    {
      "start": 27.96,
      "end": 29.48,
      "text": "我需要你们两个人"
    },
    {
      "start": 29.72,
      "end": 30.64,
      "text": "两两一组"
    },
    {
      "start": 30.92,
      "end": 31.84,
      "text": "然后站起来"
    },
    {
      "start": 32.44,
      "end": 34.52,
      "text": "待会我们看一下站起来还能不能拍得了"
    },
    {
      "start": 34.52,
      "end": 35.2,
      "text": "站起来了"
    },
    {
      "start": 35.2,
      "end": 36.36,
      "text": "你们面对对方"
    },
    {
      "start": 36.36,
      "end": 37.480000000000004,
      "text": "距离是多少呢"
