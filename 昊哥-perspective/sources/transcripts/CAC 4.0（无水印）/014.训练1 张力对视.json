    },
    {
      "start": 109.92,
      "end": 111.2,
      "text": "就是稍微有一点这样"
    },
    {
      "start": 111.2,
      "end": 113.08000000000001,
      "text": "拿手你可以摟住他的位置"
    },
    {
      "start": 113.08000000000001,
      "end": 114.36000000000001,
      "text": "我们来量量一组"
    },
    {
      "start": 114.92,
      "end": 115.76,
