    },
    {
      "start": 57.36000000000001,
      "end": 57.64,
      "text": "好"
    },
    {
      "start": 58.720000000000006,
      "end": 60.36000000000001,
      "text": "那个咱们俩演示一下"
    },
    {
      "start": 60.36000000000001,
      "end": 61.6,
      "text": "因为要不然人家取不上"
    },
    {
      "start": 63.480000000000004,
      "end": 63.720000000000006,
      "text": "对"
    },
    {
      "start": 63.88,
      "end": 64.92,
      "text": "他就对视的过程中"
    },
    {
      "start": 64.92,
      "end": 66.12,
      "text": "大家我们就这个距离"
    },
    {
      "start": 67.32000000000001,
      "end": 71.96000000000001,
      "text": "这个过程里有的时候会笑成把眼睛挪开"
    },
    {
      "start": 71.96000000000001,
      "end": 73.72,
      "text": "不要笑把眼睛挪开"
    },
    {
      "start": 74.08000000000001,
