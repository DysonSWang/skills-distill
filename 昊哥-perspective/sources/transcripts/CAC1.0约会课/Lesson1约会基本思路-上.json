    {
      "start": 64.0,
      "end": 65.0,
      "text": "第二"
    },
    {
      "start": 65.0,
      "end": 68.0,
      "text": "我会把咱们CC聊天法做一个延伸"
    },
    {
      "start": 68.0,
      "end": 72.0,
