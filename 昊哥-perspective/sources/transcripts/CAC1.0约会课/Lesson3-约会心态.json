{
  "video": "CAC1.0约会课/Lesson3-约会心态.mp4",
  "language": "zh",
  "duration": 509.5386875,
  "segments": [
    {
      "start": 0.0,
      "end": 6.4,
      "text": "【CAC约会课】"
    },
    {
      "start": 6.4,
      "end": 7.5600000000000005,
      "text": "Hello 大家好"
    },
    {
      "start": 7.5600000000000005,
      "end": 9.72,
      "text": "欢迎来到 CAC约会课"
    },
    {
      "start": 9.72,
      "end": 10.68,
      "text": "我是浩哥"
    },
    {
      "start": 10.68,
      "end": 11.56,
      "text": "在上一节课"
    },
    {
      "start": 11.56,
      "end": 12.88,
      "text": "我给大家分析了"
    },
    {
      "start": 12.88,
      "end": 15.56,
      "text": "约会和聊天最大的区别"
    },
    {
      "start": 15.56,
      "end": 16.76,
      "text": "也初步解读了"
    },
    {
      "start": 16.76,
      "end": 19.04,
      "text": "约会里面女生的心态"
    },
    {
      "start": 19.04,
      "end": 20.12,
      "text": "那么这节课"
    },
    {
      "start": 20.12,
      "end": 21.52,
      "text": "我们就来说一说"
    },
    {
      "start": 21.52,
      "end": 23.96,
      "text": "想要拥有一场完美的约会"
    },
    {
      "start": 23.96,
      "end": 27.12,
      "text": "我们自己该带着什么样的心态呢"
    },
    {
      "start": 27.12,
      "end": 27.88,
      "text": "首先"
    },
    {
      "start": 27.88,
      "end": 29.92,
      "text": "约会里最重要的一件事"
    },
    {
      "start": 29.96,
      "end": 31.8,
      "text": "就是做自己"
    },
    {
      "start": 31.8,
      "end": 33.96,
      "text": "之前很多兄弟会跟我说"
    },
    {
      "start": 33.96,
      "end": 34.84,
      "text": "约会的时候"
    },
    {
      "start": 34.84,
      "end": 36.400000000000006,
      "text": "自己特别紧张"
    },
    {
      "start": 36.400000000000006,
      "end": 37.68,
      "text": "如临大敌"
    },
    {
      "start": 37.68,
      "end": 39.96,
      "text": "平时本来有的幽默感"
    },
    {
      "start": 39.96,
      "end": 41.400000000000006,
      "text": "掌握的操作"
    },
    {
      "start": 41.400000000000006,
      "end": 44.24,
      "text": "在约会里完全的发挥不出来"
    },
    {
      "start": 44.24,
      "end": 45.96,
      "text": "如果你也是这样的话"
    },
    {
      "start": 45.96,
      "end": 47.400000000000006,
      "text": "那么我告诉你"
    },
    {
      "start": 47.400000000000006,
      "end": 48.72,
      "text": "最大的问题是"
    },
    {
      "start": 48.72,
      "end": 51.92,
      "text": "你把约会当成了一场考试"
    },
    {
      "start": 51.92,
      "end": 55.28,
      "text": "而你把女生当成是你的考官"
    },
    {
      "start": 55.28,
      "end": 57.72,
      "text": "你觉得她有评价你的权利"
    },
    {
      "start": 57.72,
      "end": 61.839999999999996,
      "text": "觉得她掌握了你们两个人关系的生杀大权"
    },
    {
      "start": 61.839999999999996,
      "end": 62.839999999999996,
      "text": "但我告诉你"
    },
    {
      "start": 62.839999999999996,
      "end": 64.44,
      "text": "不是这样的"
    },
    {
      "start": 64.44,
      "end": 66.48,
      "text": "约会只是一场匹配"
    },
    {
      "start": 66.48,
      "end": 70.12,
      "text": "只是看你们两个人相处的搭不搭合不合适"
    },
    {
      "start": 70.12,
      "end": 73.6,
      "text": "你永远不需要在意她喜欢什么样的人"
    },
    {
      "start": 73.6,
      "end": 75.56,
      "text": "你只需要做你自己"
    },
    {
      "start": 75.56,
      "end": 77.2,
      "text": "做更好的自己"
    },
    {
      "start": 77.2,
      "end": 79.24,
      "text": "如果她没跟你看对眼"
    },
    {
      "start": 79.24,
      "end": 81.0,
      "text": "那不是你的问题"
    },
    {
      "start": 81.0,
      "end": 84.2,
      "text": "是她错过了一个你这么好的人"
    },
    {
      "start": 84.2,
      "end": 87.28,
      "text": "丧失了一个深入了解你的机会"
    },
    {
      "start": 87.28,
      "end": 90.44,
      "text": "所以在约会之前你只要记住一点"
    },
    {
      "start": 90.44,
      "end": 93.36,
      "text": "你只需要做你真实的自己"
    },
    {
      "start": 93.36,
      "end": 95.92,
      "text": "你和你哥们出门是一个什么样的状态"
    },
    {
      "start": 95.92,
      "end": 99.52,
      "text": "在这个女生面前你就保持什么样的状态"
    },
    {
      "start": 99.52,
      "end": 101.6,
      "text": "甚至你可以忘记所有操作"
    },
    {
      "start": 101.6,
      "end": 103.76,
      "text": "你只需要做到自信"
    },
    {
      "start": 103.76,
      "end": 104.72,
      "text": "真实"
    },
    {
      "start": 104.72,
      "end": 105.8,
      "text": "不表演"
    },
    {
      "start": 105.8,
      "end": 107.04,
      "text": "这就够了"
    },
    {
      "start": 107.04,
      "end": 110.76,
      "text": "这种状态已经能在女生面前脱颖而出了"
    },
    {
      "start": 110.76,
      "end": 113.56,
      "text": "因为绝大多数的男人在约会的时候"
    },
    {
      "start": 113.56,
      "end": 115.16,
      "text": "都会去刻意的表演"
    },
    {
      "start": 115.16,
      "end": 117.0,
      "text": "或者刻意装逼"
    },
    {
      "start": 117.04,
      "end": 119.48,
      "text": "要么表现过度的热情"
    },
    {
      "start": 119.48,
      "end": 120.88,
      "text": "礼貌绅士"
    },
    {
      "start": 120.88,
      "end": 122.76,
      "text": "过度照顾女生"
    },
    {
      "start": 122.76,
      "end": 124.8,
      "text": "要么就是说故意的冷淡"
    },
    {
      "start": 124.8,
      "end": 128.76,
      "text": "强行表现出无所谓的这种低虚者感的态度"
    },
    {
      "start": 128.76,
      "end": 132.96,
      "text": "这种在女生眼里都是一种很装的行为"
    },
    {
      "start": 132.96,
      "end": 137.92000000000002,
      "text": "她明白你做这一切都是为了吸引她的眼球"
    },
    {
      "start": 137.92000000000002,
      "end": 140.04,
      "text": "博得她的注意力"
    },
    {
      "start": 140.04,
      "end": 141.92000000000002,
      "text": "她不会觉得你好"
    },
    {
      "start": 141.92000000000002,
      "end": 144.84,
      "text": "反而会觉得你大概率是不是没什么机会"
    },
    {
      "start": 144.84,
      "end": 146.44,
      "text": "跟我这样的女生约会"
    },
    {
      "start": 146.44,
      "end": 148.96,
      "text": "所以她本能的就会对你排斥"
    },
    {
      "start": 148.96,
      "end": 151.24,
      "text": "觉得你油腻或者是装逼"
    },
    {
      "start": 151.24,
      "end": 154.4,
      "text": "所以咱们约会心态的第一点"
    },
    {
      "start": 154.4,
      "end": 155.28,
      "text": "做你自己"
    },
    {
      "start": 156.28,
      "end": 158.35999999999999,
      "text": "除了没有做自己之外"
    },
    {
      "start": 158.35999999999999,
      "end": 160.96,
      "text": "还有很多人的一个心态误区是"
    },
    {
      "start": 160.96,
      "end": 165.07999999999998,
      "text": "把约会的目标设定成了让她开心"
    },
    {
      "start": 165.07999999999998,
      "end": 167.52,
      "text": "所以所有事情的出发点"
    },
    {
      "start": 167.52,
      "end": 169.64,
      "text": "包括约会项目的安排"
    },
    {
      "start": 169.64,
      "end": 170.92,
      "text": "时间的选择"
    },
    {
      "start": 170.92,
      "end": 173.32,
      "text": "甚至你说的话点的菜"
    },
    {
      "start": 173.32,
      "end": 176.16,
      "text": "每个点都是在为了让她开心"
    },
    {
      "start": 176.16,
      "end": 180.16,
      "text": "而就忽略了轻视了你自己的感受"
    },
    {
      "start": 180.16,
      "end": 181.28,
      "text": "这样一来"
    },
    {
      "start": 181.28,
      "end": 185.28,
      "text": "你就会不可避免的进入一种受害者的状态"
    },
    {
      "start": 185.28,
      "end": 186.51999999999998,
      "text": "因为你会觉得"
    },
    {
      "start": 186.51999999999998,
      "end": 189.4,
      "text": "我精心设计我付出了这么多"
    },
    {
      "start": 189.4,
      "end": 191.0,
      "text": "你却不领情"
    },
    {
      "start": 191.0,
      "end": 194.64,
      "text": "我们内心一定会产生一种牺牲感"
    },
    {
      "start": 194.64,
      "end": 196.84,
      "text": "甚至是愤怒感"
    },
    {
      "start": 196.84,
      "end": 198.44,
      "text": "这一切的一切"
    },
    {
      "start": 198.44,
      "end": 200.84,
      "text": "问题到底出在了哪儿呢?"
    },
    {
      "start": 200.84,
      "end": 205.2,
      "text": "那就是你对约会的目标设定错误"
    },
    {
      "start": 205.24,
      "end": 208.28000000000003,
      "text": "约会从来不是为了讨女生开心"
    },
    {
      "start": 208.28000000000003,
      "end": 210.92000000000002,
      "text": "而是为了让你自己开心"
    },
    {
      "start": 210.92000000000002,
      "end": 213.36,
      "text": "因为你付出了这么多的时间"
    },
    {
      "start": 213.36,
      "end": 214.44000000000003,
      "text": "金钱"
    },
    {
      "start": 214.44000000000003,
      "end": 215.52,
      "text": "精力"
    },
    {
      "start": 215.52,
      "end": 217.16000000000003,
      "text": "你唯一要负责的人"
    },
    {
      "start": 217.16000000000003,
      "end": 219.24,
      "text": "就是你自己的心情"
    },
    {
      "start": 219.24,
      "end": 220.68,
      "text": "那今天我要告诉你"
    },
    {
      "start": 220.68,
      "end": 223.92000000000002,
      "text": "约会最重要的事情只有四个字"
    },
    {
      "start": 223.92000000000002,
      "end": 225.4,
      "text": "自娱自乐"
    },
    {
      "start": 225.4,
      "end": 228.76000000000002,
      "text": "你一定要发自内心的愿意来这场约会"
    },
    {
      "start": 228.76000000000002,
      "end": 230.48000000000002,
      "text": "那你才应该来"
    },
    {
      "start": 230.48000000000002,
      "end": 231.4,
      "text": "来了以后"
    },
    {
      "start": 231.4,
      "end": 232.8,
      "text": "你做的每件事"
    },
    {
      "start": 232.8,
      "end": 234.32000000000002,
      "text": "你说的每句话"
    },
    {
      "start": 234.32,
      "end": 236.95999999999998,
      "text": "一定是要让你自己开心的"
    },
    {
      "start": 236.95999999999998,
      "end": 239.16,
      "text": "哪怕这个女生今天不在"
    },
    {
      "start": 239.16,
      "end": 241.64,
      "text": "那如果这些事你依然愿意做"
    },
    {
      "start": 241.64,
      "end": 243.68,
      "text": "那你才应该去做"
    },
    {
      "start": 243.68,
      "end": 246.2,
      "text": "而当你真正享受了约会"
    },
    {
      "start": 246.2,
      "end": 247.79999999999998,
      "text": "You really having fun"
    },
    {
      "start": 247.79999999999998,
      "end": 251.35999999999999,
      "text": "你才能表露出所有自信的抢购通"
    },
    {
      "start": 251.35999999999999,
      "end": 254.28,
      "text": "你才能拥有这种开放的情绪"
    },
    {
      "start": 254.28,
      "end": 256.32,
      "text": "那女生看到你的状态"
    },
    {
      "start": 256.32,
      "end": 258.8,
      "text": "她的情绪就会被你所传染"
    },
    {
      "start": 258.8,
      "end": 261.24,
      "text": "她的内心也会开心起来"
    },
    {
      "start": 261.24,
      "end": 262.08,
      "text": "所以"
    },
    {
      "start": 262.08,
      "end": 263.8,
      "text": "约会心态的第二点"
    },
    {
      "start": 263.8,
      "end": 265.64,
      "text": "我们就要上升一个高度"
    },
    {
      "start": 265.64,
      "end": 268.40000000000003,
      "text": "学习约会和约会操作的目的"
    },
    {
      "start": 268.40000000000003,
      "end": 271.2,
      "text": "就是为了让我们自己更开心"
    },
    {
      "start": 271.2,
      "end": 272.40000000000003,
      "text": "状态更好"
    },
    {
      "start": 272.40000000000003,
      "end": 274.28000000000003,
      "text": "得到更好的反馈"
    },
    {
      "start": 274.28000000000003,
      "end": 277.24,
      "text": "以此形成一个正向的循环"
    },
    {
      "start": 277.24,
      "end": 278.16,
      "text": "最终"
    },
    {
      "start": 278.16,
      "end": 280.96000000000004,
      "text": "用你一种放松自信的情绪"
    },
    {
      "start": 280.96000000000004,
      "end": 283.24,
      "text": "去吸引到女生"
    },
    {
      "start": 283.24,
      "end": 284.24,
      "text": "想象一下"
    },
    {
      "start": 284.24,
      "end": 286.04,
      "text": "如果约会设计的再好"
    },
    {
      "start": 286.04,
      "end": 287.76,
      "text": "甚至场景再浪漫"
    },
    {
      "start": 287.76,
      "end": 290.04,
      "text": "那我们的状态是紧绷的"
    },
    {
      "start": 290.04,
      "end": 292.28000000000003,
      "text": "那一切又有什么用啊"
    },
    {
      "start": 292.28000000000003,
      "end": 295.32000000000005,
      "text": "女生只会因为你的紧绷而不舒服"
    },
    {
      "start": 295.32000000000005,
      "end": 296.56,
      "text": "更拘谨"
    },
    {
      "start": 296.56,
      "end": 299.36,
      "text": "就算你带她随便吃个大排档"
    },
    {
      "start": 299.36,
      "end": 301.44000000000005,
      "text": "只要你的状态是开心"
    },
    {
      "start": 301.44000000000005,
      "end": 303.28000000000003,
      "text": "放松自信的"
    },
    {
      "start": 303.28000000000003,
      "end": 306.96000000000004,
      "text": "你就能够把她吸进到你的vibe里的来"
    },
    {
      "start": 306.96000000000004,
      "end": 309.24,
      "text": "让她跟你一起开心"
    },
    {
      "start": 309.24,
      "end": 309.88000000000005,
      "text": "这样子"
    },
    {
      "start": 309.88000000000005,
      "end": 311.56000000000006,
      "text": "她就很容易愿意"
    },
    {
      "start": 311.56000000000006,
      "end": 313.56000000000006,
      "text": "甚至是主动跟你约见"
    },
    {
      "start": 313.56000000000006,
      "end": 314.8,
      "text": "下一次见面"
    },
    {
      "start": 314.8,
      "end": 316.84000000000003,
      "text": "那么心态里的第三点"
    },
    {
      "start": 316.84000000000003,
      "end": 318.36,
      "text": "筛选心态"
    },
    {
      "start": 318.36,
      "end": 321.48,
      "text": "很多男生在约会经验比较少的时候"
    },
    {
      "start": 321.48,
      "end": 324.56,
      "text": "会把每一次约会都看得过度重要"
    },
    {
      "start": 324.56,
      "end": 328.04,
      "text": "或者是把一个还不够了解的约会对象"
    },
    {
      "start": 328.04,
      "end": 330.04,
      "text": "看得过于重要"
    },
    {
      "start": 330.04,
      "end": 330.6,
      "text": "当然了"
    },
    {
      "start": 330.6,
      "end": 332.48,
      "text": "我们都是要彼此尊重"
    },
    {
      "start": 332.48,
      "end": 334.12,
      "text": "但你必须意识到"
    },
    {
      "start": 334.12,
      "end": 335.56,
      "text": "每一次约会都是"
    },
    {
      "start": 335.56,
      "end": 338.48,
      "text": "你们双方双向筛选的过程"
    },
    {
      "start": 338.48,
      "end": 341.64000000000004,
      "text": "不能说光是她在向你施加压力"
    },
    {
      "start": 341.64000000000004,
      "end": 344.88,
      "text": "然后让我们去想办法破解废测"
    },
    {
      "start": 344.88,
      "end": 347.24,
      "text": "你也要有一个清晰的意识"
    },
    {
      "start": 347.24,
      "end": 348.76,
      "text": "就是如果这个女生"
    },
    {
      "start": 348.76,
      "end": 350.24,
      "text": "做了什么让你觉得不舒服"
    },
    {
      "start": 350.28000000000003,
      "end": 351.84000000000003,
      "text": "或者她很low的事情"
    },
    {
      "start": 351.84000000000003,
      "end": 353.56,
      "text": "比如说辱骂服务员"
    },
    {
      "start": 353.56,
      "end": 355.96000000000004,
      "text": "第一次见面就像你要这要那"
    },
    {
      "start": 355.96000000000004,
      "end": 358.72,
      "text": "或者太过度的高冷装逼"
    },
    {
      "start": 358.72,
      "end": 359.96000000000004,
      "text": "那你就知道"
    },
    {
      "start": 359.96000000000004,
      "end": 363.32,
      "text": "这个女生可能不是一个合适的对象"
    },
    {
      "start": 363.32,
      "end": 365.96000000000004,
      "text": "你就要把她给筛选掉"
    },
    {
      "start": 365.96000000000004,
      "end": 368.0,
      "text": "如果你明明知道她不好"
    },
    {
      "start": 368.0,
      "end": 369.92,
      "text": "还舍不得筛选"
    },
    {
      "start": 369.92,
      "end": 372.32,
      "text": "那就不是你约会里的问题"
    },
    {
      "start": 372.32,
      "end": 374.84000000000003,
      "text": "而是你平时社交渠道"
    },
    {
      "start": 374.84000000000003,
      "end": 378.04,
      "text": "认识女生实在太少了导致的"
    },
    {
      "start": 378.08000000000004,
      "end": 380.44,
      "text": "那你就要多去参加社交聚会"
    },
    {
      "start": 380.44,
      "end": 382.40000000000003,
      "text": "比如说读诗会"
    },
    {
      "start": 382.40000000000003,
      "end": 383.76000000000005,
      "text": "桌游剧本杀"
    },
    {
      "start": 383.76000000000005,
      "end": 385.64000000000004,
      "text": "或者一些社交酒会"
    },
    {
      "start": 385.64000000000004,
      "end": 388.8,
      "text": "再或者你就要去学习主动出击的能力"
    },
    {
      "start": 388.8,
      "end": 391.44,
      "text": "再去磨练你的搭讪技巧"
    },
    {
      "start": 391.44,
      "end": 392.64000000000004,
      "text": "那话说回来"
    },
    {
      "start": 392.64000000000004,
      "end": 394.76,
      "text": "带着这样一种筛选的意识"
    },
    {
      "start": 394.76,
      "end": 398.76,
      "text": "你会自然而然的把话题引导得更深入"
    },
    {
      "start": 398.76,
      "end": 402.72,
      "text": "去问出女生很多的真实想法和经历"
    },
    {
      "start": 402.72,
      "end": 404.36,
      "text": "你也会更容易的"
    },
    {
      "start": 404.36,
      "end": 406.72,
      "text": "敢去放松的调侃对方"
    },
    {
      "start": 406.72,
      "end": 408.8,
      "text": "给出这个推拉的操作"
    },
    {
      "start": 408.8,
      "end": 411.40000000000003,
      "text": "最后心态里的第四点"
    },
    {
      "start": 411.40000000000003,
      "end": 413.36,
      "text": "也是最重要的一点"
    },
    {
      "start": 413.36,
      "end": 414.6,
      "text": "自信"
    },
    {
      "start": 414.6,
      "end": 418.24,
      "text": "我需要给大家重塑一个对于约会的认知"
    },
    {
      "start": 418.24,
      "end": 420.68,
      "text": "那就是你一定要清晰的明白"
    },
    {
      "start": 420.68,
      "end": 422.48,
      "text": "女生愿意跟你见面"
    },
    {
      "start": 422.48,
      "end": 426.64000000000004,
      "text": "就代表你是她当前最好的选择"
    },
    {
      "start": 426.64000000000004,
      "end": 429.36,
      "text": "那女生能为了你放弃在家休息"
    },
    {
      "start": 429.36,
      "end": 431.32000000000005,
      "text": "推掉她的朋友闺蜜"
    },
    {
      "start": 431.32000000000005,
      "end": 434.96000000000004,
      "text": "甚至可能推掉了不止一个其他男生的邀约"
    },
    {
      "start": 434.96000000000004,
      "end": 437.96000000000004,
      "text": "而选择拿出这个时间专门来见你"
    },
    {
      "start": 437.96000000000004,
      "end": 442.40000000000003,
      "text": "能提前一两个小时化妆专门坐车出来"
    },
    {
      "start": 442.40000000000003,
      "end": 445.76000000000005,
      "text": "这就说明你是她此时此刻"
    },
    {
      "start": 445.76000000000005,
      "end": 448.6,
      "text": "至少今天或者是今天下午"
    },
    {
      "start": 448.6,
      "end": 451.04,
      "text": "最棒的那个约会人选"
    },
    {
      "start": 451.04,
      "end": 454.08000000000004,
      "text": "所以你理所应当自信"
    },
    {
      "start": 454.08000000000004,
      "end": 456.40000000000003,
      "text": "理所应当理直气壮"
    },
    {
      "start": 456.40000000000003,
      "end": 457.24,
      "text": "你要知道"
    },
    {
      "start": 457.24,
      "end": 460.64000000000004,
      "text": "她就是想从你身上分到一些好的体验"
    },
    {
      "start": 460.64000000000004,
      "end": 461.68000000000006,
      "text": "好的情绪"
    },
    {
      "start": 461.68000000000006,
      "end": 463.20000000000005,
      "text": "而当她出门的那一刻"
    },
    {
      "start": 463.2,
      "end": 465.56,
      "text": "就代表她已经认定"
    },
    {
      "start": 465.56,
      "end": 468.59999999999997,
      "text": "她了解的你能够给她这些"
    },
    {
      "start": 468.59999999999997,
      "end": 469.88,
      "text": "可能有人会问"
    },
    {
      "start": 469.88,
      "end": 470.64,
      "text": "哎 浩哥"
    },
    {
      "start": 470.64,
      "end": 476.2,
      "text": "这个听起来好像跟上节课女生验货的心态有所冲突"
    },
    {
      "start": 476.2,
      "end": 477.08,
      "text": "那我告诉你"
    },
    {
      "start": 477.08,
      "end": 479.08,
      "text": "毫不冲突"
    },
    {
      "start": 479.08,
      "end": 484.44,
      "text": "她出门时就是认为你是她此时此刻最好的一个获选"
    },
    {
      "start": 484.44,
      "end": 486.4,
      "text": "最棒的约会对象"
    },
    {
      "start": 486.4,
      "end": 489.88,
      "text": "但是你再好的货源也要验货"
    },
    {
      "start": 489.92,
      "end": 494.88,
      "text": "这就是为什么我让你对她也要有筛选心态"
    },
    {
      "start": 494.88,
      "end": 496.56,
      "text": "懂得了这四点心态"
    },
    {
      "start": 496.56,
      "end": 499.08,
      "text": "就能保证你约会方向的正确"
    },
    {
      "start": 499.08,
      "end": 502.84,
      "text": "也能保证你不至于做出太出格的举动"
    },
    {
      "start": 502.84,
      "end": 504.12,
      "text": "那下一节课"
    },
    {
      "start": 504.12,
      "end": 506.36,
      "text": "我们开始进入时操阶段"
    },
    {
      "start": 506.36,
      "end": 509.48,
      "text": "教会你完美约会的流程安排"
    }
  ]
}