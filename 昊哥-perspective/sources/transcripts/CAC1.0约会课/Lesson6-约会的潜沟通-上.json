{
  "video": "CAC1.0约会课/Lesson6-约会的潜沟通-上.mp4",
  "language": "zh",
  "duration": 547.7819375,
  "segments": [
    {
      "start": 0.0,
      "end": 2.0,
      "text": "欢迎来到CAC约会课"
    },
    {
      "start": 2.0,
      "end": 3.0,
      "text": "我是浩哥"
    },
    {
      "start": 3.0,
      "end": 4.0,
      "text": "在上一节课里"
    },
    {
      "start": 4.0,
      "end": 7.0,
      "text": "我们在CAC聊天法的基础上"
    },
    {
      "start": 7.0,
      "end": 10.0,
      "text": "拓展了一些语言聊天的操作"
    },
    {
      "start": 10.0,
      "end": 11.0,
      "text": "而在这节课"
    },
    {
      "start": 11.0,
      "end": 14.0,
      "text": "我们会把重点从我们的语言沟通"
    },
    {
      "start": 14.0,
      "end": 17.0,
      "text": "转移到非语言沟通上"
    },
    {
      "start": 17.0,
      "end": 19.0,
      "text": "这节课教给大家"
    },
    {
      "start": 19.0,
      "end": 21.0,
      "text": "约会当中的潜沟通"
    },
    {
      "start": 21.0,
      "end": 22.0,
      "text": "大家回忆一下"
    },
    {
      "start": 22.0,
      "end": 23.0,
      "text": "有的时候"
    },
    {
      "start": 23.0,
      "end": 24.0,
      "text": "在跟朋友聊天的时候"
    },
    {
      "start": 24.0,
      "end": 26.0,
      "text": "我们会把重点从我们的语言沟通"
    },
    {
      "start": 26.0,
      "end": 28.0,
      "text": "转移到非语言沟通上"
    },
    {
      "start": 28.0,
      "end": 29.0,
      "text": "回忆一下"
    },
    {
      "start": 29.0,
      "end": 30.0,
      "text": "有的时候"
    },
    {
      "start": 30.0,
      "end": 31.0,
      "text": "在跟别人聊天"
    },
    {
      "start": 31.0,
      "end": 32.0,
      "text": "或者说见面的时候"
    },
    {
      "start": 32.0,
      "end": 34.0,
      "text": "就算对方没怎么说话"
    },
    {
      "start": 34.0,
      "end": 37.0,
      "text": "我们依然能够识别他的情绪"
    },
    {
      "start": 37.0,
      "end": 39.0,
      "text": "猜懂他的意思"
    },
    {
      "start": 39.0,
      "end": 41.0,
      "text": "比如说你走在大街上"
    },
    {
      "start": 41.0,
      "end": 43.0,
      "text": "你斜前方有个人"
    },
    {
      "start": 43.0,
      "end": 45.0,
      "text": "身体前倾的小跑过来"
    },
    {
      "start": 45.0,
      "end": 46.0,
      "text": "善笑的对你说"
    },
    {
      "start": 46.0,
      "end": 47.0,
      "text": "你好帅哥"
    },
    {
      "start": 47.0,
      "end": 49.0,
      "text": "是不是接下来你就能猜到"
    },
    {
      "start": 49.0,
      "end": 51.0,
      "text": "他是要让你做个头发"
    },
    {
      "start": 51.0,
      "end": 53.0,
      "text": "或者是游泳前身了解一下"
    },
    {
      "start": 53.0,
      "end": 54.0,
      "text": "再比如"
    },
    {
      "start": 54.0,
      "end": 56.0,
      "text": "如果是你在老板"
    },
    {
      "start": 56.0,
      "end": 57.0,
      "text": "或者是你的老师面前"
    },
    {
      "start": 57.0,
      "end": 59.0,
      "text": "你把写好了的文章递给他"
    },
    {
      "start": 59.0,
      "end": 61.0,
      "text": "对方面无表情"
    },
    {
      "start": 61.0,
      "end": 62.0,
      "text": "看了一会儿"
    },
    {
      "start": 62.0,
      "end": 64.0,
      "text": "突然眉头一皱"
    },
    {
      "start": 64.0,
      "end": 66.0,
      "text": "你是不是立刻就知道"
    },
    {
      "start": 66.0,
      "end": 67.0,
      "text": "坏了"
    },
    {
      "start": 67.0,
      "end": 68.0,
      "text": "我写错了"
    },
    {
      "start": 68.0,
      "end": 69.0,
      "text": "又挨骂了"
    },
    {
      "start": 69.0,
      "end": 71.0,
      "text": "当我们在外面吃饭"
    },
    {
      "start": 71.0,
      "end": 72.0,
      "text": "隔壁桌"
    },
    {
      "start": 72.0,
      "end": 74.0,
      "text": "有一对小情侣去吵架"
    },
    {
      "start": 74.0,
      "end": 75.0,
      "text": "女生说"
    },
    {
      "start": 75.0,
      "end": 77.0,
      "text": "你昨天晚上不接我电话"
    },
    {
      "start": 77.0,
      "end": 78.0,
      "text": "你到底干嘛去了"
    },
    {
      "start": 78.0,
      "end": 79.0,
      "text": "男生说"
    },
    {
      "start": 79.0,
      "end": 81.0,
      "text": "我就跟室友去网吧了"
    },
    {
      "start": 81.0,
      "end": 83.0,
      "text": "你能别无理取闹吗"
    },
    {
      "start": 83.0,
      "end": 85.0,
      "text": "你看到男生的反应"
    },
    {
      "start": 85.0,
      "end": 87.0,
      "text": "是不是基本就能知道"
    },
    {
      "start": 87.0,
      "end": 88.0,
      "text": "他没干好事"
    },
    {
      "start": 88.0,
      "end": 90.0,
      "text": "为什么我们能够做出"
    },
    {
      "start": 90.0,
      "end": 92.0,
      "text": "上面这些判断呢"
    },
    {
      "start": 92.0,
      "end": 94.0,
      "text": "答案其实就是三个字"
    },
    {
      "start": 94.0,
      "end": 95.0,
      "text": "浅沟通"
    },
    {
      "start": 95.0,
      "end": 98.0,
      "text": "当我们人与人当面互动的时候"
    },
    {
      "start": 98.0,
      "end": 100.0,
      "text": "由语言传递的信息"
    },
    {
      "start": 100.0,
      "end": 102.0,
      "text": "实际上只占7%"
    },
    {
      "start": 102.0,
      "end": 104.0,
      "text": "而剩下的93%"
    },
    {
      "start": 104.0,
      "end": 107.0,
      "text": "都是靠我们的浅沟通来传递的"
    },
    {
      "start": 107.0,
      "end": 110.0,
      "text": "那浅沟通包括哪些呢"
    },
    {
      "start": 110.0,
      "end": 111.0,
      "text": "声音"
    },
    {
      "start": 111.0,
      "end": 112.0,
      "text": "音调"
    },
    {
      "start": 112.0,
      "end": 113.0,
      "text": "眼神"
    },
    {
      "start": 113.0,
      "end": 114.0,
      "text": "表情"
    },
    {
      "start": 114.0,
      "end": 115.0,
      "text": "表情"
    },
    {
      "start": 115.0,
      "end": 117.0,
      "text": "肢体语言等等"
    },
    {
      "start": 117.0,
      "end": 118.0,
      "text": "在约会中"
    },
    {
      "start": 118.0,
      "end": 122.0,
      "text": "每一个点都会起到非常重要的作用"
    },
    {
      "start": 122.0,
      "end": 124.0,
      "text": "因为跟语言沟通相比"
    },
    {
      "start": 124.0,
      "end": 125.0,
      "text": "浅沟通"
    },
    {
      "start": 125.0,
      "end": 127.0,
      "text": "它是更难被意识到"
    },
    {
      "start": 127.0,
      "end": 128.0,
      "text": "更难训练"
    },
    {
      "start": 128.0,
      "end": 129.0,
      "text": "更难改变"
    },
    {
      "start": 129.0,
      "end": 131.0,
      "text": "也是更难伪装的"
    },
    {
      "start": 131.0,
      "end": 132.0,
      "text": "但相反"
    },
    {
      "start": 132.0,
      "end": 135.0,
      "text": "它也是更能展现出你的真实价值"
    },
    {
      "start": 135.0,
      "end": 137.0,
      "text": "一个人说的话"
    },
    {
      "start": 137.0,
      "end": 138.0,
      "text": "那个文字很自信"
    },
    {
      "start": 138.0,
      "end": 139.0,
      "text": "可是呢"
    },
    {
      "start": 139.0,
      "end": 141.0,
      "text": "他说话的语气却顿顿叙叙"
    },
    {
      "start": 141.0,
      "end": 143.0,
      "text": "眼神躲闪乱飘"
    },
    {
      "start": 143.0,
      "end": 144.0,
      "text": "那你就知道"
    },
    {
      "start": 144.0,
      "end": 146.0,
      "text": "他虽然在强装自信"
    },
    {
      "start": 146.0,
      "end": 147.0,
      "text": "强装淡定"
    },
    {
      "start": 147.0,
      "end": 150.0,
      "text": "但他的骨子里是非常慌乱的"
    },
    {
      "start": 150.0,
      "end": 152.0,
      "text": "所以很多人"
    },
    {
      "start": 152.0,
      "end": 154.0,
      "text": "之所以掌握了聊天技巧"
    },
    {
      "start": 154.0,
      "end": 158.0,
      "text": "在约会里却依然不能建立系"
    },
    {
      "start": 158.0,
      "end": 161.0,
      "text": "最大的问题就是浅沟通做的太差"
    },
    {
      "start": 161.0,
      "end": 162.0,
      "text": "所以接下来"
    },
    {
      "start": 162.0,
      "end": 164.0,
      "text": "就让我分别告诉大家"
    },
    {
      "start": 164.0,
      "end": 168.0,
      "text": "上面的几点浅沟通该具体如何操作"
    },
    {
      "start": 168.0,
      "end": 169.0,
      "text": "第一种声音"
    },
    {
      "start": 169.0,
      "end": 173.0,
      "text": "在约会或者是任何的社交场合"
    },
    {
      "start": 173.0,
      "end": 175.0,
      "text": "一种有自信的声音"
    },
    {
      "start": 175.0,
      "end": 178.0,
      "text": "在音量上一定是让对方能听清的"
    },
    {
      "start": 178.0,
      "end": 180.0,
      "text": "回应一下平时生活里"
    },
    {
      "start": 180.0,
      "end": 182.0,
      "text": "你是否有被别人问过"
    },
    {
      "start": 182.0,
      "end": 183.0,
      "text": "你说什么"
    },
    {
      "start": 183.0,
      "end": 184.0,
      "text": "我没听清"
    },
    {
      "start": 184.0,
      "end": 185.0,
      "text": "如果有的话"
    },
    {
      "start": 185.0,
      "end": 189.0,
      "text": "就说明你的声音卡在了自己的小空间里"
    },
    {
      "start": 189.0,
      "end": 190.0,
      "text": "而声音模糊"
    },
    {
      "start": 190.0,
      "end": 191.0,
      "text": "音量小"
    },
    {
      "start": 191.0,
      "end": 195.0,
      "text": "是最容易被别人认为没有自信的"
    },
    {
      "start": 195.0,
      "end": 196.0,
      "text": "因为这个说明的"
    },
    {
      "start": 196.0,
      "end": 199.0,
      "text": "你不敢用声音去打破别人的边界"
    },
    {
      "start": 199.0,
      "end": 202.0,
      "text": "所以如果是音量太小的兄弟"
    },
    {
      "start": 202.0,
      "end": 205.0,
      "text": "你首先就需要去锻炼自己"
    },
    {
      "start": 205.0,
      "end": 207.0,
      "text": "逐渐放大你的声音"
    },
    {
      "start": 207.0,
      "end": 209.0,
      "text": "这样在跟女生说话的时候"
    },
    {
      "start": 209.0,
      "end": 212.0,
      "text": "起码能给到她强烈的印象"
    },
    {
      "start": 212.0,
      "end": 213.0,
      "text": "第二点声调"
    },
    {
      "start": 213.0,
      "end": 217.0,
      "text": "这个是99%的人都会忽略到的"
    },
    {
      "start": 217.0,
      "end": 219.0,
      "text": "一个浅沟通的细节"
    },
    {
      "start": 219.0,
      "end": 223.0,
      "text": "声调是有很强的化文化差异"
    },
    {
      "start": 223.0,
      "end": 225.0,
      "text": "所以这里我们所说的"
    },
    {
      "start": 225.0,
      "end": 228.0,
      "text": "仅限于中文和英文"
    },
    {
      "start": 228.0,
      "end": 231.0,
      "text": "我们很多人在面对女生的时候"
    },
    {
      "start": 231.0,
      "end": 232.0,
      "text": "或者说是面对一个"
    },
    {
      "start": 232.0,
      "end": 235.0,
      "text": "任何一个地位比自己更高的人的时候"
    },
    {
      "start": 235.0,
      "end": 238.0,
      "text": "我们本能的就会声调上扬"
    },
    {
      "start": 238.0,
      "end": 240.0,
      "text": "比如说你好"
    },
    {
      "start": 240.0,
      "end": 242.0,
      "text": "今天辛苦了累不累"
    },
    {
      "start": 242.0,
      "end": 245.0,
      "text": "或者说没问题您放心"
    },
    {
      "start": 245.0,
      "end": 247.0,
      "text": "当我这话一出口"
    },
    {
      "start": 247.0,
      "end": 249.0,
      "text": "其实你就能听出"
    },
    {
      "start": 249.0,
      "end": 252.0,
      "text": "我的社交地位要比对方更低"
    },
    {
      "start": 252.0,
      "end": 254.0,
      "text": "我的底气不足"
    },
    {
      "start": 254.0,
      "end": 256.0,
      "text": "因为我上扬的这种声调"
    },
    {
      "start": 256.0,
      "end": 259.0,
      "text": "就代表我多多少少有点心虚"
    },
    {
      "start": 259.0,
      "end": 261.0,
      "text": "我有一点在讨好对方"
    },
    {
      "start": 261.0,
      "end": 264.0,
      "text": "或者叫寻求认可"
    },
    {
      "start": 264.0,
      "end": 268.0,
      "text": "我的本意可能只是说表达诚意表达热情"
    },
    {
      "start": 268.0,
      "end": 271.0,
      "text": "但是这种过度的诚意和热情"
    },
    {
      "start": 271.0,
      "end": 274.0,
      "text": "就能让对方接收到一个信号"
    },
    {
      "start": 274.0,
      "end": 276.0,
      "text": "你有求于我"
    },
    {
      "start": 276.0,
      "end": 279.0,
      "text": "而且你不认为自己配得上我"
    },
    {
      "start": 279.0,
      "end": 281.0,
      "text": "或者说你提供的价值跟我对等"
    },
    {
      "start": 281.0,
      "end": 283.0,
      "text": "或者说你拿捏得住我"
    },
    {
      "start": 283.0,
      "end": 286.0,
      "text": "你不相信自己的价值和魅力"
    },
    {
      "start": 286.0,
      "end": 290.0,
      "text": "所以你才会用这种态度来寻求我的认可"
    },
    {
      "start": 290.0,
      "end": 293.0,
      "text": "那么当女生或者说你的合作伙伴"
    },
    {
      "start": 293.0,
      "end": 295.0,
      "text": "谈判对手"
    },
    {
      "start": 295.0,
      "end": 297.0,
      "text": "接收到这一个信号的时候"
    },
    {
      "start": 297.0,
      "end": 299.0,
      "text": "你的不自信或者心虚"
    },
    {
      "start": 299.0,
      "end": 302.0,
      "text": "在他们眼中就已经成了定局"
    },
    {
      "start": 302.0,
      "end": 305.0,
      "text": "而对方在心里给你减分"
    },
    {
      "start": 305.0,
      "end": 307.0,
      "text": "也成了定局"
    },
    {
      "start": 307.0,
      "end": 311.0,
      "text": "因此在约会或者是语音聊天的时候"
    },
    {
      "start": 311.0,
      "end": 313.0,
      "text": "千万不要用上扬的声调"
    },
    {
      "start": 313.0,
      "end": 315.0,
      "text": "向对方寻求认可"
    },
    {
      "start": 315.0,
      "end": 318.0,
      "text": "那么我们到底该用什么样的声调呢"
    },
    {
      "start": 318.0,
      "end": 320.0,
      "text": "平稳下降"
    },
    {
      "start": 320.0,
      "end": 322.0,
      "text": "因为这种声调背后"
    },
    {
      "start": 322.0,
      "end": 324.0,
      "text": "带来的是一种确认"
    },
    {
      "start": 324.0,
      "end": 326.0,
      "text": "笃定自信的感觉"
    },
    {
      "start": 326.0,
      "end": 327.0,
      "text": "你好"
    },
    {
      "start": 327.0,
      "end": 329.0,
      "text": "今天辛苦了累不累"
    },
    {
      "start": 329.0,
      "end": 330.0,
      "text": "没问题你放心"
    },
    {
      "start": 330.0,
      "end": 332.0,
      "text": "同样的语言没有变"
    },
    {
      "start": 332.0,
      "end": 335.0,
      "text": "只是把这个声调稍微的变化"
    },
    {
      "start": 335.0,
      "end": 339.0,
      "text": "是不是价值感和自信感就完全不同"
    },
    {
      "start": 339.0,
      "end": 341.0,
      "text": "第三点眼神"
    },
    {
      "start": 341.0,
      "end": 344.0,
      "text": "在大街上看到漂亮的女生"
    },
    {
      "start": 344.0,
      "end": 346.0,
      "text": "在她看过来的那一瞬间"
    },
    {
      "start": 346.0,
      "end": 348.0,
      "text": "你会不会把眼神挪开"
    },
    {
      "start": 348.0,
      "end": 350.0,
      "text": "那在朋友的聚会上"
    },
    {
      "start": 350.0,
      "end": 352.0,
      "text": "你身边坐下来一位"
    },
    {
      "start": 352.0,
      "end": 354.0,
      "text": "打扮非常性感的女生"
    },
    {
      "start": 354.0,
      "end": 357.0,
      "text": "你是不是顶多打一个招呼"
    },
    {
      "start": 357.0,
      "end": 359.0,
      "text": "就会假装看向别处"
    },
    {
      "start": 359.0,
      "end": 360.0,
      "text": "想象一下"
    },
    {
      "start": 360.0,
      "end": 363.0,
      "text": "当女生看到我们迫于压力"
    },
    {
      "start": 363.0,
      "end": 365.0,
      "text": "把眼神挪走的时候"
    },
    {
      "start": 365.0,
      "end": 367.0,
      "text": "对方就会立刻意识到"
    },
    {
      "start": 367.0,
      "end": 370.0,
      "text": "这个男人承受不了这种压力"
    },
    {
      "start": 370.0,
      "end": 372.0,
      "text": "而大概率"
    },
    {
      "start": 372.0,
      "end": 374.0,
      "text": "她在生活中是接触不到"
    },
    {
      "start": 374.0,
      "end": 376.0,
      "text": "像我这样的女生的"
    },
    {
      "start": 376.0,
      "end": 379.0,
      "text": "所以她就会在内心里给你减分"
    },
    {
      "start": 379.0,
      "end": 382.0,
      "text": "眼神的操作种类非常多"
    },
    {
      "start": 382.0,
      "end": 384.0,
      "text": "在线下的社交训练营里"
    },
    {
      "start": 384.0,
      "end": 386.0,
      "text": "我会带大家训练"
    },
    {
      "start": 386.0,
      "end": 387.0,
      "text": "但在我们约会课里"
    },
    {
      "start": 387.0,
      "end": 390.0,
      "text": "我们最需要最重要去解决的"
    },
    {
      "start": 390.0,
      "end": 393.0,
      "text": "那就是眼神注视 eye contact"
    },
    {
      "start": 393.0,
      "end": 394.0,
      "text": "回忆一下"
    },
    {
      "start": 394.0,
      "end": 397.0,
      "text": "你跟女生初次约会的时候"
    },
    {
      "start": 397.0,
      "end": 399.0,
      "text": "你敢不敢去温柔的"
    },
    {
      "start": 399.0,
      "end": 401.0,
      "text": "盯着她的眼睛看呢"
    },
    {
      "start": 401.0,
      "end": 403.0,
      "text": "可能很多人从小被灌输"
    },
    {
      "start": 403.0,
      "end": 406.0,
      "text": "我们盯着别人看是不礼貌的"
    },
    {
      "start": 406.0,
      "end": 409.0,
      "text": "但其实这个往往只是一个借口"
    },
    {
      "start": 409.0,
      "end": 411.0,
      "text": "我们害怕跟女生"
    },
    {
      "start": 411.0,
      "end": 413.0,
      "text": "眼神接触的真实原因是"
    },
    {
      "start": 413.0,
      "end": 416.0,
      "text": "你handle不了这种压力"
    },
    {
      "start": 416.0,
      "end": 419.0,
      "text": "眼神注视会给我们压力的原因"
    },
    {
      "start": 419.0,
      "end": 420.0,
      "text": "是有两个"
    },
    {
      "start": 420.0,
      "end": 421.0,
      "text": "第一"
    },
    {
      "start": 421.0,
      "end": 422.0,
      "text": "在自然界里"
    },
    {
      "start": 422.0,
      "end": 424.0,
      "text": "长时间的眼神注视"
    },
    {
      "start": 424.0,
      "end": 428.0,
      "text": "确实是一种跨物种的挑衅行为"
    },
    {
      "start": 428.0,
      "end": 430.0,
      "text": "如果有兄弟家里养了小猫"
    },
    {
      "start": 430.0,
      "end": 432.0,
      "text": "小狗这些宠物就会知道"
    },
    {
      "start": 432.0,
      "end": 435.0,
      "text": "你跟他们去对视的时候"
    },
    {
      "start": 435.0,
      "end": 438.0,
      "text": "他们通常会很快就把眼睛挪开"
    },
    {
      "start": 438.0,
      "end": 441.0,
      "text": "因为他们知道你才是家里的boss"
    },
    {
      "start": 441.0,
      "end": 443.0,
      "text": "自己惹不了你"
    },
    {
      "start": 443.0,
      "end": 445.0,
      "text": "他们承受不了这种压力"
    },
    {
      "start": 445.0,
      "end": 446.0,
      "text": "对我们人来说"
    },
    {
      "start": 446.0,
      "end": 449.0,
      "text": "尽管我们社会化程度这么高"
    },
    {
      "start": 449.0,
      "end": 452.0,
      "text": "但依然会被这种本能所影响"
    },
    {
      "start": 452.0,
      "end": 454.0,
      "text": "在两个人对视的时候"
    },
    {
      "start": 454.0,
      "end": 455.0,
      "text": "不论男女"
    },
    {
      "start": 455.0,
      "end": 458.0,
      "text": "基本上先扭头的那个"
    },
    {
      "start": 458.0,
      "end": 460.0,
      "text": "就是更没有安全感"
    },
    {
      "start": 460.0,
      "end": 461.0,
      "text": "更缺少自信"
    },
    {
      "start": 461.0,
      "end": 464.0,
      "text": "更害怕压力的那个"
    },
    {
      "start": 464.0,
      "end": 465.0,
      "text": "第二个原因"
    },
    {
      "start": 465.0,
      "end": 467.0,
      "text": "对我们普通人来说"
    },
    {
      "start": 467.0,
      "end": 469.0,
      "text": "生活中确实接触到"
    },
    {
      "start": 469.0,
      "end": 472.0,
      "text": "漂亮女生的密度并没有那么高"
    },
    {
      "start": 472.0,
      "end": 475.0,
      "text": "所以当这样一个人出现的时候"
    },
    {
      "start": 475.0,
      "end": 478.0,
      "text": "我们就会稍微有点不知所措"
    },
    {
      "start": 478.0,
      "end": 482.0,
      "text": "所以就想着尽可能去避免眼神交流"
    },
    {
      "start": 482.0,
      "end": 485.0,
      "text": "甚至可能会假装故意不看她"
    },
    {
      "start": 485.0,
      "end": 487.0,
      "text": "防止我们露出窘态"
    },
    {
      "start": 487.0,
      "end": 490.0,
      "text": "防止对方对我们的印象降低"
    },
    {
      "start": 490.0,
      "end": 491.0,
      "text": "懂得了这两点"
    },
    {
      "start": 491.0,
      "end": 494.0,
      "text": "她就能够帮我们去跟女生"
    },
    {
      "start": 494.0,
      "end": 497.0,
      "text": "有意识的更好地保持眼神注视"
    },
    {
      "start": 497.0,
      "end": 498.0,
      "text": "和眼神交流"
    },
    {
      "start": 498.0,
      "end": 501.0,
      "text": "当然这绝对不是让你说死死的盯着人家看"
    },
    {
      "start": 501.0,
      "end": 503.0,
      "text": "那太变态了"
    },
    {
      "start": 503.0,
      "end": 506.0,
      "text": "而是说给出一个自信的"
    },
    {
      "start": 506.0,
      "end": 508.0,
      "text": "稳定的而又温和的眼神"
    },
    {
      "start": 508.0,
      "end": 512.0,
      "text": "这种眼神既展现了你的自信和价值感"
    },
    {
      "start": 512.0,
      "end": 515.0,
      "text": "又保持了一种男对女的框架"
    },
    {
      "start": 515.0,
      "end": 518.0,
      "text": "这个是要和商业眼神分开的"
    },
    {
      "start": 518.0,
      "end": 520.0,
      "text": "大家要注意的是"
    },
    {
      "start": 520.0,
      "end": 524.0,
      "text": "如果你真的觉得眼神交流的压力太大了"
    },
    {
      "start": 524.0,
      "end": 526.0,
      "text": "那么当她说话的时候"
    },
    {
      "start": 526.0,
      "end": 530.0,
      "text": "无论如何你也要坚持住去注视她"
    },
    {
      "start": 530.0,
      "end": 532.0,
      "text": "而当我们自己说话的时候"
    },
    {
      "start": 532.0,
      "end": 535.0,
      "text": "这个时候就是我们可以喘口气的时间"
    },
    {
      "start": 535.0,
      "end": 540.0,
      "text": "你的眼神可以随着说话的手势和一些回忆而挪开"
    },
    {
      "start": 540.0,
      "end": 543.0,
      "text": "OK 除了声音眼神声调以外"
    },
    {
      "start": 543.0,
      "end": 546.0,
      "text": "还有两种非常重要的潜沟通"
    },
    {
      "start": 546.0,
      "end": 547.0,
      "text": "我们下节课接着讲"
    }
  ]
}